---
// src/pages/index.astro
// Homepage — Complete ZyrithTech landing page
// Matches the HTML design exactly with Sanity CMS integration

import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Button from '../components/Button.astro';
import CTASection from '../components/CTASection.astro';
import ValueItem from '../components/ValueItem.astro';

const clientLogos = [
  'NORTHPEAK', 'Vantage & Co', 'BRIGHTFIELD', 'Loomstack', 'CIVIC WORKS', 'Haloway', 'ORBITAL', 'Fernbridge'
];

const values = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h7l-1 8 11-14h-7l1-8z" stroke-linecap="round" stroke-linejoin="round"/></svg>',
    title: 'Fast, transparent delivery',
    description: 'Fixed sprints, weekly check-ins, and a live project dashboard — no black-box agencies.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3" stroke-linecap="round" stroke-linejoin="round"/></svg>',
    title: 'Strategy before pixels',
    description: 'Every engagement starts with research and positioning, so design and dev decisions compound.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 17l6-6 4 4 8-8" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 7h7v7" stroke-linecap="round" stroke-linejoin="round"/></svg>',
    title: 'Built to measure',
    description: 'Every project ships with analytics baked in, so you can see the ROI, not just the output.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18M8 4v5" stroke-linecap="round"/></svg>',
    title: 'One team, all disciplines',
    description: 'Strategists, engineers, and designers work in one pod — no hand-offs, no lost context.',
  },
];

// Try to fetch Sanity data, but page renders gracefully if Sanity not configured
let featuredProjects: any[] = [];
let latestPosts: any[] = [];

try {
  const { getFeaturedCaseStudies, getLatestBlogPosts } = await import('../lib/queries');
  featuredProjects = await getFeaturedCaseStudies().catch(() => []);
  latestPosts = await getLatestBlogPosts(3).catch(() => []);
} catch (error) {
  // Sanity not configured — page still renders with placeholders
}

const title = "ZyrithTech — Digital Marketing, Web Development & Brand Identity Agency";
const description = "ZyrithTech is a growth-focused digital agency for startups and SMBs. We build conversion-focused websites, SEO strategies, and paid ad systems that generate predictable inbound leads.";
const canonicalURL = "https://zyrithtech.com/";
const ogImage = "https://zyrithtech.com/images/og-home.jpg";
---

<Layout 
  title={title} 
  description={description}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
>
  <!-- JSON-LD Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "ZyrithTech",
    "url": "https://zyrithtech.com",
    "logo": "https://zyrithtech.com/images/logo.svg",
    "description": "Digital marketing, web development, and brand identity agency for startups and SMBs.",
    "sameAs": [
      "https://www.linkedin.com/company/zyrithtech",
      "https://www.instagram.com/zyrithtech",
      "https://www.twitter.com/zyrithtech"
    ]
  }
  </script>

  <!-- =====================================================
       HERO SECTION
       ===================================================== -->
  <section class="hero">
    <div class="hero-orb hero-orb-1" aria-hidden="true"></div>
    <div class="hero-orb hero-orb-2" aria-hidden="true"></div>
    <div class="container">
      <div class="hero-content">
        <span class="eyebrow hero-eyebrow reveal">
          <span class="hero-eyebrow-dot"></span>
          Digital Agency for Growth-Stage Companies
        </span>
        <h1 class="hero-h1 reveal reveal-delay-1">
          Digital solutions<br />
          built for <span class="hero-h1-accent">growth.</span>
        </h1>
        <p class="hero-sub reveal reveal-delay-2">Strategy · Web · Marketing · Identity — integrated digital systems that turn your online presence into a predictable lead generation engine.</p>
        <div class="hero-actions reveal reveal-delay-3">
          <Button href="/contact" variant="primary" size="lg">Start a Project</Button>
          <Button href="/work" variant="ghost" size="lg">See Case Studies</Button>
        </div>

        <div class="hero-stats reveal reveal-delay-3">
          <div class="hero-stat">
            <span class="hero-stat-number">200+</span>
            <span class="hero-stat-label">Projects Delivered</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-number">$15M+</span>
            <span class="hero-stat-label">Client Revenue Generated</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-number">98%</span>
            <span class="hero-stat-label">Client Satisfaction</span>
          </div>
        </div>
      </div>
    </div>

    <a href="#services" class="hero-scroll-cue" aria-label="Scroll to services">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 4v12M10 16l5-5M10 16l-5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </section>

  <!-- =====================================================
       CLIENT LOGO MARQUEE
       ===================================================== -->
  <section class="marquee-section">
    <div class="container">
      <p class="caption marquee-label">Trusted by growth-stage teams across industries</p>
    </div>
    <div class="marquee-track-wrap">
      <div class="marquee-track">
        {[...clientLogos, ...clientLogos].map((name) => (
          <span class="marquee-wordmark">{name}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- =====================================================
       SERVICES GRID
       ===================================================== -->
  <section class="section bg-white" id="services">
    <div class="container">
      <SectionHeader
        eyebrow="What We Do"
        heading="Three Pillars of Digital Growth"
        description="We combine strategy, technology, and creativity to deliver integrated digital solutions that drive measurable results."
      />
      <div class="grid-3">
        <div class="service-card reveal">
          <span class="service-index">01</span>
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="1.5"/>
              <path d="M20 8V20M20 20L28 28M20 20L12 28" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="card-h3">Digital Marketing</h3>
          <p class="body-default">SEO, paid ads, content marketing, social media, and analytics that drive qualified leads and predictable growth.</p>
          <a href="/services/digital-marketing" class="btn-text service-link">Explore Services</a>
        </div>

        <div class="service-card reveal reveal-delay-1">
          <span class="service-index">02</span>
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="6" y="8" width="28" height="24" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M6 16H34M14 24H20M26 24H28" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="card-h3">Web Development</h3>
          <p class="body-default">Conversion-focused website design, e-commerce solutions, and hosting that turn visitors into customers.</p>
          <a href="/services/web-development" class="btn-text service-link">Explore Services</a>
        </div>

        <div class="service-card reveal reveal-delay-2">
          <span class="service-index">03</span>
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="20" cy="20" r="12" stroke="currentColor" stroke-width="1.5"/>
              <path d="M20 12V28M12 20H28" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="20" cy="20" r="2" fill="currentColor"/>
            </svg>
          </div>
          <h3 class="card-h3">Creative & Branding</h3>
          <p class="body-default">Visual design, logo creation, and brand identity systems that establish authority and stand out.</p>
          <a href="/services/creative-branding" class="btn-text service-link">Explore Services</a>
        </div>
      </div>
    </div>
  </section>

  <!-- =====================================================
       FEATURED WORK (FROM SANITY)
       ===================================================== -->
  <section class="section bg-surface">
    <div class="container">
      <SectionHeader 
        eyebrow="Case Studies"
        heading="Proven Results for Growing Brands"
        description="See how we've helped startups and SMBs achieve measurable growth through integrated digital strategies."
      />
      <div class="grid-3" id="featured-work-grid">
        {featuredProjects.length > 0 ? (
          featuredProjects.map((project, index) => (
            <a href={`/work/${project.slug.current}/`} class={`featured-work-card reveal${index > 0 ? ` reveal-delay-${index}` : ''}`}>
              <div class="featured-work-image">
                {project.featuredImage && (
                  <img 
                    src={project.featuredImage.asset.url} 
                    alt={project.title}
                    width="600"
                    height="400"
                    loading="lazy"
                    decoding="async"
                  />
                )}
              </div>
              <div class="featured-work-content">
                <div class="featured-work-meta">
                  <span>{project.client}</span>
                  <span>{project.industry}</span>
                </div>
                <h3 class="card-h3">{project.title}</h3>
                {project.results && project.results[0] && (
                  <div class="featured-work-result">
                    <span class="result-value">{project.results[0].value}</span>
                    <span class="result-label">{project.results[0].description}</span>
                  </div>
                )}
              </div>
            </a>
          ))
        ) : (
          <div style="grid-column:1/-1;padding:var(--space-16);text-align:center;color:var(--mid-slate)">
            <p class="body-default">Featured work loading from Sanity...</p>
          </div>
        )}
      </div>
      <div style="display:flex;justify-content:center;margin-top:var(--space-12)">
        <Button href="/work" variant="secondary">View All Case Studies</Button>
      </div>
    </div>
  </section>

  <!-- =====================================================
       WHY US — VALUE BAND
       ===================================================== -->
  <section class="value-band">
    <div class="container">
      <SectionHeader
        eyebrow="Why ZyrithTech"
        heading="A Different Kind of Agency"
        description="No bloated retainers, no jargon-filled reports — just senior specialists building systems that compound."
        variant="light"
      />
      <div class="value-grid">
        {values.map((value, index) => (
          <ValueItem
            icon={value.icon}
            title={value.title}
            description={value.description}
            delay={index as 0 | 1 | 2 | 3}
            variant="dark"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- =====================================================
       TESTIMONIALS SLIDER
       ===================================================== -->
  <section class="section bg-white">
    <div class="container">
      <SectionHeader
        eyebrow="Testimonials"
        heading="Trusted by Forward-Thinking Brands"
        description="Our clients share how we've transformed their digital presence and driven measurable results."
      />
      
      <div class="testimonials-wrap">
        <div class="testimonials-track" id="testimonial-track">
          <!-- Hardcoded fallback testimonials -->
          <article class="testimonial-slide">
            <div class="card-testimonial">
              <span class="quote-mark" aria-hidden="true">"</span>
              <p class="body-large testimonial-quote">"ZyrithTech transformed our entire digital presence. Within 3 months, we saw a 150% increase in qualified leads and our website now converts at 8.2%. They're not just an agency — they're a strategic partner."</p>
              <div style="display:flex;align-items:center;gap:var(--space-3)">
                <div style="width:44px;height:44px;border-radius:50%;background:var(--navy-100);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:700;font-size:.875rem;color:var(--navy-500);flex-shrink:0">RK</div>
                <div>
                  <div style="font-weight:600;font-size:var(--text-sm);color:var(--dark-slate)">Rajesh Kumar</div>
                  <div class="caption">Founder, TechStartup Co.</div>
                </div>
              </div>
            </div>
          </article>

          <article class="testimonial-slide">
            <div class="card-testimonial">
              <span class="quote-mark" aria-hidden="true">"</span>
              <p class="body-large testimonial-quote">"We tried 3 other agencies before ZyrithTech. The difference is clarity and transparency. They delivered exactly what they promised, on time, and the results speak for themselves. Highly recommend."</p>
              <div style="display:flex;align-items:center;gap:var(--space-3)">
                <div style="width:44px;height:44px;border-radius:50%;background:var(--sky-50);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:700;font-size:.875rem;color:var(--sky-700);flex-shrink:0">SP</div>
                <div>
                  <div style="font-weight:600;font-size:var(--text-sm);color:var(--dark-slate)">Sarah Patel</div>
                  <div class="caption">Marketing Lead, GrowthCorp</div>
                </div>
              </div>
            </div>
          </article>

          <article class="testimonial-slide">
            <div class="card-testimonial">
              <span class="quote-mark" aria-hidden="true">"</span>
              <p class="body-large testimonial-quote">"Best investment we made this year. Our SEO went from page 5 to page 1 for our main keywords. They explained everything clearly and never oversold. They delivered real value."</p>
              <div style="display:flex;align-items:center;gap:var(--space-3)">
                <div style="width:44px;height:44px;border-radius:50%;background:var(--orange-50);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:700;font-size:.875rem;color:var(--orange-700);flex-shrink:0">MJ</div>
                <div>
                  <div style="font-weight:600;font-size:var(--text-sm);color:var(--dark-slate)">Mohit Joshi</div>
                  <div class="caption">CEO, LocalServices.in</div>
                </div>
              </div>
            </div>
          </article>
        </div>
      </div>

      <div style="display:flex;align-items:center;justify-content:center;gap:var(--space-4);margin-top:var(--space-12)">
        <div class="testimonial-dots" id="testimonial-dots">
          <button class="testimonial-dot active" data-index="0" role="tab" aria-selected="true" aria-label="Testimonial 1"></button>
          <button class="testimonial-dot" data-index="1" role="tab" aria-selected="false" aria-label="Testimonial 2"></button>
          <button class="testimonial-dot" data-index="2" role="tab" aria-selected="false" aria-label="Testimonial 3"></button>
        </div>
      </div>
    </div>
  </section>

  <!-- =====================================================
       LATEST BLOG POSTS (FROM SANITY)
       ===================================================== -->
  <section class="section bg-white">
    <div class="container">
      <SectionHeader 
        eyebrow="Blog"
        heading="Insights & Strategy"
        description="Learn the strategies and tactics we use to drive results for our clients."
      />
      
      <div class="grid-3" id="blog-grid">
        {latestPosts.length > 0 ? (
          latestPosts.map((post, index) => {
            const publishDate = post.publishedAt 
              ? new Date(post.publishedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
              : '';
            
            return (
              <a href={`/blog/${post.slug.current}/`} class={`blog-card reveal${index > 0 ? ` reveal-delay-${index}` : ''}`}>
                <div class="blog-card-img-wrap">
                  {post.mainImage ? (
                    <img 
                      src={post.mainImage.asset.url}
                      alt={post.title}
                      width="600"
                      height="180"
                      loading="lazy"
                      decoding="async"
                      class="blog-card-img"
                    />
                  ) : (
                    <div style="background:linear-gradient(135deg,var(--navy-700),var(--navy-500));display:flex;align-items:center;justify-content:center;height:100%">
                      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="1.5">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10 9 9 9 8 9"/>
                      </svg>
                    </div>
                  )}
                </div>
                <div class="blog-card-body">
                  <div class="blog-card-meta">
                    {post.categories && post.categories[0] && (
                      <span class="blog-card-cat">{post.categories[0].title}</span>
                    )}
                    {publishDate && (
                      <span class="blog-card-date">{publishDate}</span>
                    )}
                  </div>
                  <h3 class="blog-card-title">{post.title}</h3>
                  <p class="blog-card-excerpt">{post.excerpt}</p>
                  <span class="blog-read-more">Read Article</span>
                </div>
              </a>
            );
          })
        ) : (
          <div style="grid-column:1/-1;padding:var(--space-16);text-align:center;color:var(--mid-slate)">
            <p class="body-default">Articles loading from Sanity...</p>
          </div>
        )}
      </div>

      <div style="display:flex;justify-content:center;margin-top:var(--space-12)">
        <Button href="/blog" variant="secondary">View All Articles</Button>
      </div>
    </div>
  </section>

  <!-- =====================================================
       CTA SECTION
       ===================================================== -->
  <CTASection 
    eyebrow="Ready to Grow?"
    heading="Let's Build Your Digital Engine"
    subtext="Schedule a free 30-minute strategy call to explore how we can drive measurable results for your business."
    primaryBtn={{ text: "Start Your Project", href: "/contact" }}
    secondaryBtn={{ text: "View Our Services", href: "/services" }}
  />

</Layout>

<style>
  /* Hero */
  .hero {
    background-color: var(--navy-500);
    padding-block: clamp(var(--space-20), 12vw, 8rem) var(--space-24);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 100% at 80% 0%, rgba(91, 170, 255, 0.14) 0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 20% 100%, rgba(255, 123, 53, 0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .hero-orb-1 {
    width: 420px;
    height: 420px;
    top: -160px;
    right: -80px;
    background: radial-gradient(circle, rgba(61, 148, 245, 0.35) 0%, transparent 70%);
  }

  .hero-orb-2 {
    width: 320px;
    height: 320px;
    bottom: -140px;
    left: -60px;
    background: radial-gradient(circle, rgba(255, 123, 53, 0.16) 0%, transparent 70%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 760px;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--sky-300);
    margin-bottom: var(--space-5);
    padding: var(--space-2) var(--space-4);
    border: 1px solid rgba(91, 170, 255, 0.3);
    border-radius: var(--radius-full);
    background-color: rgba(91, 170, 255, 0.06);
  }

  .hero-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--orange-300);
    flex-shrink: 0;
    box-shadow: 0 0 0 3px rgba(255, 123, 53, 0.2);
  }

  .hero-h1 {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: var(--tracking-tight);
    color: var(--white);
    margin-bottom: var(--space-6);
  }

  .hero-h1-accent {
    color: var(--orange-300);
    font-style: italic;
  }

  .hero-sub {
    font-size: var(--text-lg);
    color: var(--navy-100);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
    max-width: 560px;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-16);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    padding-top: var(--space-8);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .hero-stat-number {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--white);
    line-height: 1.1;
  }

  .hero-stat-label {
    font-size: var(--text-xs);
    color: var(--navy-200);
  }

  .hero-stat-divider {
    width: 1px;
    height: 32px;
    background-color: rgba(255, 255, 255, 0.15);
  }

  @media (max-width: 640px) {
    .hero-stat-divider { display: none; }
  }

  .hero-scroll-cue {
    position: absolute;
    left: 50%;
    bottom: var(--space-8);
    transform: translateX(-50%);
    color: var(--navy-100);
    opacity: 0.7;
    animation: bounceCue 2.2s var(--ease-in-out) infinite;
    z-index: 1;
  }

  .hero-scroll-cue:hover {
    color: var(--white);
    opacity: 1;
  }

  @keyframes bounceCue {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  @media (max-width: 768px) {
    .hero-scroll-cue { display: none; }
  }

  /* Client logo marquee */
  .marquee-wordmark {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--mid-slate);
    opacity: 0.55;
    white-space: nowrap;
    letter-spacing: 0.01em;
    transition: opacity var(--duration-base) var(--ease-out), color var(--duration-base) var(--ease-out);
  }

  .marquee-wordmark:hover {
    opacity: 1;
    color: var(--navy-500);
  }

  /* Service Cards */
  .service-card {
    background-color: var(--white);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: relative;
    transition: box-shadow var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out), border-color var(--duration-base) var(--ease-out);
  }

  .service-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    border-color: var(--sky-200);
  }

  .service-index {
    position: absolute;
    top: var(--space-6);
    right: var(--space-8);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--lt-stroke);
