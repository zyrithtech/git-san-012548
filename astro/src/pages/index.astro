---
// src/pages/index.astro
// Homepage — Complete ZyrithTech landing page
// Matches the HTML design exactly with Sanity CMS integration.

import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Button from '../components/Button.astro';
import CTASection from '../components/CTASection.astro';

// Try to fetch Sanity data, but page renders gracefully if Sanity not configured
let featuredProjects: any[] = [];
let latestPosts: any[] = [];

try {
  const { getFeaturedCaseStudies, getLatestBlogPosts } = await import('../lib/queries');
  featuredProjects = await getFeaturedCaseStudies().catch(() => []);
  latestPosts = await getLatestBlogPosts(3).catch(() => []);
} catch (error) {
  // Sanity not configured — page still renders with placeholders
}

const title = "ZyrithTech — Digital Marketing, Web Development & Brand Identity Agency";
const description = "ZyrithTech is a growth-focused digital agency for startups and SMBs. We build conversion-focused websites, SEO strategies, and paid ad systems that generate predictable inbound leads.";
const canonicalURL = "https://zyrithtech.com/";
const ogImage = "https://zyrithtech.com/images/og-home.jpg";
---

<Layout 
  title={title} 
  description={description}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
>
  <!-- JSON-LD Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "ZyrithTech",
    "url": "https://zyrithtech.com",
    "logo": "https://zyrithtech.com/images/logo.svg",
    "description": "Digital marketing, web development, and brand identity agency for startups and SMBs.",
    "sameAs": [
      "https://www.linkedin.com/company/zyrithtech",
      "https://www.instagram.com/zyrithtech",
      "https://www.twitter.com/zyrithtech"
    ]
  }
  </script>

  <!-- =====================================================
       HERO SECTION
       ===================================================== -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <span class="eyebrow">Digital Agency for Growth-Stage Companies</span>
        <h1 class="hero-h1">Digital Solutions Built for Growth</h1>
        <p class="hero-sub">Strategy · Web · Marketing · Identity — integrated digital systems that turn your online presence into a predictable lead generation engine.</p>
        <div class="hero-actions">
          <Button href="/contact" variant="primary" size="lg">Start a Project</Button>
          <Button href="/work" variant="secondary" size="lg">See Case Studies</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- =====================================================
       STATS BAND
       ===================================================== -->
  <section class="stats-band">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item reveal">
          <div class="stat-number">200+</div>
          <div class="stat-label">Projects Delivered</div>
        </div>
        <div class="stat-item reveal reveal-delay-1">
          <div class="stat-number">$15M+</div>
          <div class="stat-label">Client Revenue Generated</div>
        </div>
        <div class="stat-item reveal reveal-delay-2">
          <div class="stat-number">98%</div>
          <div class="stat-label">Client Satisfaction</div>
        </div>
        <div class="stat-item reveal reveal-delay-3">
          <div class="stat-number">2 Years</div>
          <div class="stat-label">Trusted by Industry</div>
        </div>
      </div>
    </div>
  </section>

  <!-- =====================================================
       SERVICES GRID
       ===================================================== -->
  <section class="section bg-white">
    <div class="container">
      <SectionHeader 
        eyebrow="What We Do"
        heading="Three Pillars of Digital Growth"
        description="We combine strategy, technology, and creativity to deliver integrated digital solutions that drive measurable results."
      />
      <div class="grid-3">
        <div class="service-card reveal">
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="1.5"/>
              <path d="M20 8V20M20 20L28 28M20 20L12 28" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="card-h3">Digital Marketing</h3>
          <p class="body-default">SEO, paid ads, content marketing, social media, and analytics that drive qualified leads and predictable growth.</p>
          <a href="/services/digital-marketing" class="btn-text">Explore Services</a>
        </div>

        <div class="service-card reveal reveal-delay-1">
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="6" y="8" width="28" height="24" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M6 16H34M14 24H20M26 24H28" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="card-h3">Web Development</h3>
          <p class="body-default">Conversion-focused website design, e-commerce solutions, and hosting that turn visitors into customers.</p>
          <a href="/services/web-development" class="btn-text">Explore Services</a>
        </div>

        <div class="service-card reveal reveal-delay-2">
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="20" cy="20" r="12" stroke="currentColor" stroke-width="1.5"/>
              <path d="M20 12V28M12 20H28" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="20" cy="20" r="2" fill="currentColor"/>
            </svg>
          </div>
          <h3 class="card-h3">Creative & Branding</h3>
          <p class="body-default">Visual design, logo creation, and brand identity systems that establish authority and stand out.</p>
          <a href="/services/creative-branding" class="btn-text">Explore Services</a>
        </div>
      </div>
    </div>
  </section>

  <!-- =====================================================
       FEATURED WORK (FROM SANITY)
       ===================================================== -->
  <section class="section bg-surface">
    <div class="container">
      <SectionHeader 
        eyebrow="Case Studies"
        heading="Proven Results for Growing Brands"
        description="See how we've helped startups and SMBs achieve measurable growth through integrated digital strategies."
      />
      <div class="grid-3" id="featured-work-grid">
        {featuredProjects.length > 0 ? (
          featuredProjects.map((project, index) => (
            <a href={`/work/${project.slug.current}/`} class={`featured-work-card reveal${index > 0 ? ` reveal-delay-${index}` : ''}`}>
              <div class="featured-work-image">
                {project.featuredImage && (
                  <img 
                    src={project.featuredImage.asset.url} 
                    alt={project.title}
                    width="600"
                    height="400"
                    loading="lazy"
                    decoding="async"
                  />
                )}
              </div>
              <div class="featured-work-content">
                <div class="featured-work-meta">
                  <span>{project.client}</span>
                  <span>{project.industry}</span>
                </div>
                <h3 class="card-h3">{project.title}</h3>
                {project.results && project.results[0] && (
                  <div class="featured-work-result">
                    <span class="result-value">{project.results[0].value}</span>
                    <span class="result-label">{project.results[0].description}</span>
                  </div>
                )}
              </div>
            </a>
          ))
        ) : (
          <div style="grid-column:1/-1;padding:var(--space-16);text-align:center;color:var(--mid-slate)">
            <p class="body-default">Featured work loading from Sanity...</p>
          </div>
        )}
      </div>
      <div style="display:flex;justify-content:center;margin-top:var(--space-12)">
        <Button href="/work" variant="secondary">View All Case Studies</Button>
      </div>
    </div>
  </section>

  <!-- =====================================================
       TESTIMONIALS SLIDER
       ===================================================== -->
  <section class="section bg-white">
    <div class="container">
      <SectionHeader 
        eyebrow="Testimonials"
        heading="Trusted by Forward-Thinking Brands"
        description="Our clients share how we've transformed their digital presence and driven measurable results."
      />
      
      <div class="testimonials-wrap">
        <div class="testimonials-track" id="testimonial-track">
          <!-- Hardcoded fallback testimonials -->
          <article class="testimonial-slide">
            <div class="card-testimonial">
              <span class="quote-mark" aria-hidden="true">"</span>
              <p class="body-large testimonial-quote">"ZyrithTech transformed our entire digital presence. Within 3 months, we saw a 150% increase in qualified leads and our website now converts at 8.2%. They're not just an agency — they're a strategic partner."</p>
              <div style="display:flex;align-items:center;gap:var(--space-3)">
                <div style="width:44px;height:44px;border-radius:50%;background:var(--navy-100);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:700;font-size:.875rem;color:var(--navy-500);flex-shrink:0">RK</div>
                <div>
                  <div style="font-weight:600;font-size:var(--text-sm);color:var(--dark-slate)">Rajesh Kumar</div>
                  <div class="caption">Founder, TechStartup Co.</div>
                </div>
              </div>
            </div>
          </article>

          <article class="testimonial-slide">
            <div class="card-testimonial">
              <span class="quote-mark" aria-hidden="true">"</span>
              <p class="body-large testimonial-quote">"We tried 3 other agencies before ZyrithTech. The difference is clarity and transparency. They delivered exactly what they promised, on time, and the results speak for themselves. Highly recommend."</p>
              <div style="display:flex;align-items:center;gap:var(--space-3)">
                <div style="width:44px;height:44px;border-radius:50%;background:var(--sky-50);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:700;font-size:.875rem;color:var(--sky-700);flex-shrink:0">SP</div>
                <div>
                  <div style="font-weight:600;font-size:var(--text-sm);color:var(--dark-slate)">Sarah Patel</div>
                  <div class="caption">Marketing Lead, GrowthCorp</div>
                </div>
              </div>
            </div>
          </article>

          <article class="testimonial-slide">
            <div class="card-testimonial">
              <span class="quote-mark" aria-hidden="true">"</span>
              <p class="body-large testimonial-quote">"Best investment we made this year. Our SEO went from page 5 to page 1 for our main keywords. They explained everything clearly and never oversold. They delivered real value."</p>
              <div style="display:flex;align-items:center;gap:var(--space-3)">
                <div style="width:44px;height:44px;border-radius:50%;background:var(--orange-50);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:700;font-size:.875rem;color:var(--orange-700);flex-shrink:0">MJ</div>
                <div>
                  <div style="font-weight:600;font-size:var(--text-sm);color:var(--dark-slate)">Mohit Joshi</div>
                  <div class="caption">CEO, LocalServices.in</div>
                </div>
              </div>
            </div>
          </article>
        </div>
      </div>

      <div style="display:flex;align-items:center;justify-content:center;gap:var(--space-4);margin-top:var(--space-12)">
        <div class="testimonial-dots" id="testimonial-dots">
          <button class="testimonial-dot active" data-index="0" role="tab" aria-selected="true" aria-label="Testimonial 1"></button>
          <button class="testimonial-dot" data-index="1" role="tab" aria-selected="false" aria-label="Testimonial 2"></button>
          <button class="testimonial-dot" data-index="2" role="tab" aria-selected="false" aria-label="Testimonial 3"></button>
        </div>
      </div>
    </div>
  </section>

  <!-- =====================================================
       LATEST BLOG POSTS (FROM SANITY)
       ===================================================== -->
  <section class="section bg-white">
    <div class="container">
      <SectionHeader 
        eyebrow="Blog"
        heading="Insights & Strategy"
        description="Learn the strategies and tactics we use to drive results for our clients."
      />
      
      <div class="grid-3" id="blog-grid">
        {latestPosts.length > 0 ? (
          latestPosts.map((post, index) => {
            const publishDate = post.publishedAt 
              ? new Date(post.publishedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
              : '';
            
            return (
              <a href={`/blog/${post.slug.current}/`} class={`blog-card reveal${index > 0 ? ` reveal-delay-${index}` : ''}`}>
                <div class="blog-card-img-wrap">
                  {post.mainImage ? (
                    <img 
                      src={post.mainImage.asset.url}
                      alt={post.title}
                      width="600"
                      height="180"
                      loading="lazy"
                      decoding="async"
                      class="blog-card-img"
                    />
                  ) : (
                    <div style="background:linear-gradient(135deg,var(--navy-700),var(--navy-500));display:flex;align-items:center;justify-content:center;height:100%">
                      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="1.5">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10 9 9 9 8 9"/>
                      </svg>
                    </div>
                  )}
                </div>
                <div class="blog-card-body">
                  <div class="blog-card-meta">
                    {post.categories && post.categories[0] && (
                      <span class="blog-card-cat">{post.categories[0].title}</span>
                    )}
                    {publishDate && (
                      <span class="blog-card-date">{publishDate}</span>
                    )}
                  </div>
                  <h3 class="blog-card-title">{post.title}</h3>
                  <p class="blog-card-excerpt">{post.excerpt}</p>
                  <a href={`/blog/${post.slug.current}/`} class="blog-read-more">Read Article</a>
                </div>
              </a>
            );
          })
        ) : (
          <div style="grid-column:1/-1;padding:var(--space-16);text-align:center;color:var(--mid-slate)">
            <p class="body-default">Articles loading from Sanity...</p>
          </div>
        )}
      </div>

      <div style="display:flex;justify-content:center;margin-top:var(--space-12)">
        <Button href="/blog" variant="secondary">View All Articles</Button>
      </div>
    </div>
  </section>

  <!-- =====================================================
       CTA SECTION
       ===================================================== -->
  <CTASection 
    eyebrow="Ready to Grow?"
    heading="Let's Build Your Digital Engine"
    subtext="Schedule a free 30-minute strategy call to explore how we can drive measurable results for your business."
    primaryBtn={{ text: "Start Your Project", href: "/contact" }}
    secondaryBtn={{ text: "View Our Services", href: "/services" }}
  />

</Layout>

<style>
  /* Hero */
  .hero {
    background-color: var(--navy-500);
    padding-block: var(--space-24);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 100% at 80% 0%, rgba(91, 170, 255, 0.1) 0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 20% 100%, rgba(255, 123, 53, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 720px;
  }

  .hero .eyebrow {
    color: var(--sky-300);
    display: block;
    margin-bottom: var(--space-4);
  }

  .hero-h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    font-weight: 700;
    line-height: 1.10;
    letter-spacing: var(--tracking-tight);
    color: var(--white);
    margin-bottom: var(--space-5);
  }

  .hero-sub {
    font-size: var(--text-lg);
    color: var(--navy-100);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
    max-width: 560px;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* Stats Band */
  .stats-band {
    background-color: var(--white);
    padding-block: var(--space-16);
    border-top: 1px solid var(--color-border-default);
    border-bottom: 1px solid var(--color-border-default);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-8);
  }

  @media (max-width: 1024px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .stats-grid { grid-template-columns: 1fr; }
  }

  .stat-item {
    text-align: center;
    padding: var(--space-6) 0;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: 700;
    color: var(--navy-500);
    line-height: 1.1;
    margin-bottom: var(--space-2);
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 500;
  }

  /* Service Cards */
  .service-card {
    background-color: var(--white);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: box-shadow var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
  }

  .service-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .service-icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-lg);
    background-color: var(--sky-50);
    color: var(--sky-500);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .service-card:hover .service-icon {
    background-color: var(--navy-50);
    color: var(--navy-500);
  }

  /* Featured Work */
  .featured-work-card {
    background-color: var(--white);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: box-shadow var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  .featured-work-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
  }

  .featured-work-image {
    height: 220px;
    overflow: hidden;
    background-color: var(--navy-50);
  }

  .featured-work-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .featured-work-card:hover .featured-work-image img {
    transform: scale(1.03);
  }

  .featured-work-content {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .featured-work-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    font-size: var(--text-xs);
  }

  .featured-work-meta span:first-child {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sky-500);
  }

  .featured-work-meta span:last-child {
    color: var(--color-text-muted);
  }

  .featured-work-result {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    margin-top: auto;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border-default);
  }

  .result-value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--orange-300);
  }

  .result-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* Testimonials */
  .testimonials-wrap {
    position: relative;
    margin-bottom: var(--space-12);
    min-height: 300px;
  }

  .testimonials-track {
    display: grid;
    grid-template-columns: 1fr;
  }

  .testimonial-slide {
    opacity: 0;
    transform: scale(0.95);
    transition: opacity var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
    position: absolute;
    width: 100%;
    left: 0;
    top: 0;
    pointer-events: none;
  }

  .testimonial-slide.active {
    opacity: 1;
    transform: scale(1);
    position: relative;
    pointer-events: auto;
  }

  .card-testimonial {
    background-color: var(--white);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    box-shadow: var(--shadow-card);
  }

  .quote-mark {
    font-size: 3rem;
    color: var(--sky-300);
    opacity: 0.2;
    font-family: var(--font-display);
    line-height: 1;
    margin-bottom: var(--space-2);
    display: block;
  }

  .testimonial-quote {
    margin-bottom: var(--space-6);
    font-style: italic;
  }

  .testimonial-dots {
    display: flex;
    gap: var(--space-2);
  }

  .testimonial-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--lt-stroke);
    border: none;
    cursor: pointer;
    transition: background-color var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
  }

  .testimonial-dot.active {
    background-color: var(--navy-500);
    transform: scale(1.25);
  }

  /* Blog Cards */
  .blog-card {
    background-color: var(--white);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .blog-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .blog-card-img-wrap {
    height: 180px;
    flex-shrink: 0;
    overflow: hidden;
    background-color: var(--navy-50);
  }

  .blog-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .blog-card:hover .blog-card-img {
    transform: scale(1.03);
  }

  .blog-card-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .blog-card-cat {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--sky-500);
  }

  .blog-card-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .blog-card-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--navy-900);
    margin-bottom: var(--space-3);
    line-height: var(--leading-snug);
  }

  .blog-card-excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-5);
    flex: 1;
  }

  .blog-read-more {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--sky-500);
    margin-top: auto;
    transition: color var(--duration-fast) var(--ease-out);
    text-decoration: none;
  }

  .blog-read-more::after {
    content: '→';
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .blog-card:hover .blog-read-more {
    color: var(--sky-700);
  }

  .blog-card:hover .blog-read-more::after {
    transform: translateX(3px);
  }

  /* Animations */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity var(--duration-slower) var(--ease-out), transform var(--duration-slower) var(--ease-out);
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-delay-1 { transition-delay: 100ms; }
  .reveal-delay-2 { transition-delay: 200ms; }
  .reveal-delay-3 { transition-delay: 300ms; }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  // Scroll reveal animations
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  }

  // Testimonial slider
  function initTestimonialSlider() {
    const track = document.getElementById('testimonial-track');
    const dots = document.querySelectorAll('.testimonial-dot');
    const slides = document.querySelectorAll('.testimonial-slide');
    
    if (!track || !slides.length) return;

    let current = 0;
    const total = slides.length;

    const show = (index: number) => {
      slides.forEach((s, i: number) => s.classList.toggle('active', i === index));
      dots.forEach((d, i: number) => {
        d.classList.toggle('active', i === index);
        d.setAttribute('aria-selected', i === index ? 'true' : 'false');
      });
    };

    show(0);
    dots.forEach((dot, i: number) => dot.addEventListener('click', () => {
      current = i;
      show(current);
    }));

    setInterval(() => {
      current = (current + 1) % total;
      show(current);
    }, 6000);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTestimonialSlider);
  } else {
    initTestimonialSlider();
  }
</script>