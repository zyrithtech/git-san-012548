---
// src/pages/index.astro
// Homepage — Complete ZyrithTech landing page
// Matches the HTML design exactly with Sanity CMS integration

import Layout from '../layouts/Layout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Button from '../components/Button.astro';
import CTASection from '../components/CTASection.astro';
import ValueItem from '../components/ValueItem.astro';

const clientLogos = [
  'Neuriphy', 'Emry Networks', 'Regentra', 'Quick Hire', 'New Era India', 'Minerva HRD', 'Logistics Coordinators'
];

// TEMP dummy copy — replace every quote with the client's actual words before launch.
const testimonials = [
  { quote: "Working with ZyrithTech felt less like hiring an agency and more like adding a strategic team. The new site is finally converting the way our brand deserves.", client: 'Neuriphy', service: 'Website Development' },
  { quote: "They took the time to understand our positioning before touching a single pixel. The brand identity feels like us — just sharper.", client: 'Emry Networks', service: 'Branding' },
  { quote: "Our organic visibility improved steadily month over month. What stood out was how clearly they explained the strategy behind every recommendation.", client: 'Regentra', service: 'SEO & Marketing' },
  { quote: "From requirements to launch, the process stayed structured and transparent — no surprises, no scope creep, just steady progress.", client: 'Quick Hire', service: 'Website Development' },
  { quote: "ZyrithTech gave our brand a cohesive presence across every touchpoint. It finally feels like one company, not five vendors stitched together.", client: 'New Era India', service: 'Branding & Design' },
  { quote: "They approached our marketing like a growth partner, not a task-taker — asking the right questions before proposing tactics.", client: 'Minerva HRD', service: 'Digital Marketing' },
  { quote: "The new site is faster, cleaner, and easier for our team to manage, and support has been responsive whenever we've needed changes.", client: 'Logistics Coordinators', service: 'Website Maintenance & Support' },
];

const values = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3" stroke-linecap="round" stroke-linejoin="round"/></svg>',
    title: 'Strategy before pixels',
    description: 'Every engagement starts with a structured discovery process, so design and development decisions compound toward your growth goals.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h7l-1 8 11-14h-7l1-8z" stroke-linecap="round" stroke-linejoin="round"/></svg>',
    title: 'Platform-agnostic execution',
    description: 'We build on Astro, Webflow, Wix Studio, WordPress, or Shopify — whichever platform fits your business, not whichever locks you into an agency.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18M8 4v5" stroke-linecap="round"/></svg>',
    title: 'One team, all disciplines',
    description: 'Strategy, design, development, and marketing work in one pod — no hand-offs between vendors, no lost context.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 17l6-6 4 4 8-8" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 7h7v7" stroke-linecap="round" stroke-linejoin="round"/></svg>',
    title: 'Built to measure',
    description: 'Transparent milestones and documentation at every stage, so you see progress against business outcomes — not just deliverables.',
  },
];

// Try to fetch Sanity data, but page renders gracefully if Sanity not configured
let featuredProjects: any[] = [];
let latestPosts: any[] = [];

try {
  const { getFeaturedCaseStudies, getLatestBlogPosts } = await import('../lib/queries');
  featuredProjects = await getFeaturedCaseStudies().catch(() => []);
  latestPosts = await getLatestBlogPosts(3).catch(() => []);
} catch (error) {
  // Sanity not configured — page still renders with placeholders
}

const title = "ZyrithTech — Website Development, Branding & Digital Marketing Agency";
const description = "ZyrithTech (Zyrith Technologies) is a digital growth partner for startups, SMBs, and professional service firms. Website development, branding, SEO, and marketing under one accountable team — built to turn your digital presence into a consistent inquiry pipeline.";
const canonicalURL = "https://zyrithtech.com/";
const ogImage = "https://zyrithtech.com/images/og-home.jpg";

const faqs = [
  {
    question: 'What does ZyrithTech do?',
    answer: 'ZyrithTech is a digital growth partner for startups, SMBs, and professional service firms. We bring strategy, design, development, and marketing under one accountable team — building websites, brand systems, and SEO-driven marketing that turn your digital presence into a consistent inquiry pipeline, instead of five disconnected vendors.',
  },
  {
    question: 'What services does ZyrithTech offer?',
    answer: 'ZyrithTech offers three connected pillars: digital marketing (SEO, content, social, PPC, email, analytics), web development (websites and e-commerce), and creative branding (brand identity, logo, and design). Strategy, design, development, and marketing sit under one accountable team rather than separate vendors.',
  },
  {
    question: 'How much does a website or marketing project cost?',
    answer: 'Pricing is scoped to your goals, not sold as fixed packages. Websites are quoted by scope; marketing runs as a monthly retainer. We give you a clear, itemised proposal after a discovery call, so you know exactly what you are paying for before committing.',
  },
  {
    question: 'Which platforms do you build on?',
    answer: 'We are platform-agnostic and build on Astro, Webflow, Wix Studio, WordPress, or Shopify — whichever fits your business, budget, and team. We recommend the platform that serves you long-term, not the one that locks you into the agency.',
  },
  {
    question: 'How long does a typical project take?',
    answer: 'A focused website build typically launches in around 60 days, depending on scope and content readiness. SEO and marketing are ongoing and compound over months. We set a realistic timeline during the discovery call before any work begins.',
  },
  {
    question: 'What makes ZyrithTech different from other agencies?',
    answer: 'One accountable partner covers strategy, design, development, and marketing — so there are no hand-offs between vendors and no lost context. We lead with strategy, stay platform-agnostic, and report against real business outcomes like leads and revenue, not just deliverables.',
  },
  {
    question: 'Do you work with businesses outside India?',
    answer: 'Yes. Our primary market is India, and we also work with clients in the United States, the United Kingdom, Australia, and the Middle East. Projects run remotely with structured milestones and transparent reporting.',
  },
];
---

<Layout 
  title={title} 
  description={description}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
>
  <!-- Organization/WebSite JSON-LD is emitted sitewide from Layout.astro
       (schemaGraph). The homepage-only Organization block was removed to avoid
       a duplicate entity. -->

  <!-- =====================================================
       HERO SECTION
       ===================================================== -->
  <section class="hero">
    <div class="hero-orb hero-orb-1" aria-hidden="true"></div>
    <div class="hero-orb hero-orb-2" aria-hidden="true"></div>
    <div class="container">
      <div class="hero-content">
        <span class="eyebrow hero-eyebrow reveal">
          <span class="hero-eyebrow-dot"></span>
          Digital Growth Partner for Startups & SMBs
        </span>
        <h1 class="hero-h1 reveal reveal-delay-1">
          Digital solutions<br />
          built for <span class="hero-h1-accent">growth.</span>
        </h1>
        <p class="hero-sub reveal reveal-delay-2">Strategy, design, development, and marketing — under one accountable partner, built to turn your digital presence into a consistent inquiry pipeline.</p>
        <div class="hero-actions reveal reveal-delay-3">
          <Button href="/contact" variant="primary" size="lg">Book a Discovery Call</Button>
          <Button href="/work" variant="ghost" size="lg">See Case Studies</Button>
        </div>

        <div class="hero-stats reveal reveal-delay-3">
          <div class="hero-stat">
            <span class="hero-stat-number">6+</span>
            <span class="hero-stat-label">Platforms & Stacks</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-number">5</span>
            <span class="hero-stat-label">Markets Served</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-number">60 Days</span>
            <span class="hero-stat-label">Typical Launch Timeline</span>
          </div>
        </div>
      </div>
    </div>

    <a href="#services" class="hero-scroll-cue" aria-label="Scroll to services">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 4v12M10 16l5-5M10 16l-5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </section>

  <!-- =====================================================
       CLIENT LOGO MARQUEE
       ===================================================== -->
  <section class="marquee-section">
    <div class="container">
      <p class="caption marquee-label">Trusted by growing teams across India, the US, UK & beyond</p>
    </div>
    <div class="marquee-track-wrap">
      <div class="marquee-track">
        {[...clientLogos, ...clientLogos].map((name) => (
          <span class="marquee-wordmark">{name}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- =====================================================
       SERVICES GRID
       ===================================================== -->
  <section class="section bg-white" id="services">
    <div class="container">
      <SectionHeader
        eyebrow="What We Do"
        heading="Three Pillars of Digital Growth"
        description="Strategy, design, development, and marketing under one accountable partner — not five disconnected vendors."
      />
      <div class="grid-3">
        <div class="service-card reveal">
          <span class="service-index">01</span>
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="1.5"/>
              <path d="M20 8V20M20 20L28 28M20 20L12 28" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="card-h3">Digital Marketing</h3>
          <p class="body-default">SEO, content marketing, social media, and performance marketing that build a consistent, qualified lead pipeline.</p>
          <a href="/services/digital-marketing" class="btn-text service-link">Explore Services</a>
        </div>

        <div class="service-card reveal reveal-delay-1">
          <span class="service-index">02</span>
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="6" y="8" width="28" height="24" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M6 16H34M14 24H20M26 24H28" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="card-h3">Web Development</h3>
          <p class="body-default">Platform-agnostic website and e-commerce development — Astro, Webflow, Wix Studio, WordPress, or Shopify, built around what your business needs.</p>
          <a href="/services/web-development" class="btn-text service-link">Explore Services</a>
        </div>

        <div class="service-card reveal reveal-delay-2">
          <span class="service-index">03</span>
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="20" cy="20" r="12" stroke="currentColor" stroke-width="1.5"/>
              <path d="M20 12V28M12 20H28" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="20" cy="20" r="2" fill="currentColor"/>
            </svg>
          </div>
          <h3 class="card-h3">Creative & Branding</h3>
          <p class="body-default">Brand identity, UI/UX design, and design systems that give a growing business a cohesive, credible presence.</p>
          <a href="/services/creative-branding" class="btn-text service-link">Explore Services</a>
        </div>
      </div>
    </div>
  </section>

  <!-- =====================================================
       FEATURED WORK (FROM SANITY)
       ===================================================== -->
  <section class="section bg-surface">
    <div class="container">
      <SectionHeader 
        eyebrow="Case Studies"
        heading="Proven Results for Growing Brands"
        description="See how we've helped startups and SMBs achieve measurable growth through integrated digital strategies."
      />
      <div class="grid-3" id="featured-work-grid">
        {featuredProjects.length > 0 ? (
          featuredProjects.map((project, index) => (
            <a href={`/work/${project.slug.current}/`} class={`featured-work-card reveal${index > 0 ? ` reveal-delay-${index}` : ''}`}>
              <div class="featured-work-image">
                {project.featuredImage && (
                  <img 
                    src={project.featuredImage.asset.url} 
                    alt={project.featuredImage?.alt || project.title}
                    width="600"
                    height="400"
                    loading="lazy"
                    decoding="async"
                  />
                )}
              </div>
              <div class="featured-work-content">
                <div class="featured-work-meta">
                  <span>{project.client}</span>
                  <span>{project.industry}</span>
                </div>
                <h3 class="card-h3">{project.title}</h3>
                {project.results && project.results[0] && (
                  <div class="featured-work-result">
                    <span class="result-value">{project.results[0].value}</span>
                    <span class="result-label">{project.results[0].description}</span>
                  </div>
                )}
              </div>
            </a>
          ))
        ) : (
          <div style="grid-column:1/-1;padding:var(--space-16);text-align:center;color:var(--mid-slate)">
            <p class="body-default">Featured work loading from Sanity...</p>
          </div>
        )}
      </div>
      <div style="display:flex;justify-content:center;margin-top:var(--space-12)">
        <Button href="/work" variant="secondary">View All Case Studies</Button>
      </div>
    </div>
  </section>

  <!-- =====================================================
       WHY US — VALUE BAND
       ===================================================== -->
  <section class="value-band">
    <div class="container">
      <SectionHeader
        eyebrow="Why ZyrithTech"
        heading="A Different Kind of Agency"
        description="One accountable partner across strategy, design, development, and marketing — structured delivery, real business outcomes, no jargon."
        variant="light"
      />
      <div class="value-grid">
        {values.map((value, index) => (
          <ValueItem
            icon={value.icon}
            title={value.title}
            description={value.description}
            delay={index as 0 | 1 | 2 | 3}
            variant="dark"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- =====================================================
       TESTIMONIALS SLIDER
       ===================================================== -->
  <section class="section bg-white">
    <div class="container">
      <SectionHeader
        eyebrow="Testimonials"
        heading="What Our Clients Say"
        description="Feedback from the teams we've partnered with — full quotes are being finalized with each client."
      />

      <div class="testimonials-wrap">
        <!-- TEMP dummy quotes (see `testimonials` above) — swap in real client
             testimonials before launch. -->
        <div class="testimonials-track" id="testimonial-track">
          {testimonials.map((t, index) => (
            <article class={`testimonial-slide${index === 0 ? ' active' : ''}`}>
              <div class="card-testimonial">
                <span class="quote-mark" aria-hidden="true">"</span>
                <p class="body-large testimonial-quote">"{t.quote}"</p>
                <div class="caption">— {t.client} · {t.service}</div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div style="display:flex;align-items:center;justify-content:center;gap:var(--space-4);margin-top:var(--space-12)">
        <div class="testimonial-dots" id="testimonial-dots">
          {testimonials.map((t, index) => (
            <button
              class={`testimonial-dot${index === 0 ? ' active' : ''}`}
              data-index={index}
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              aria-label={`Testimonial ${index + 1}`}
            ></button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- =====================================================
       LATEST BLOG POSTS (FROM SANITY)
       ===================================================== -->
  <section class="section bg-white">
    <div class="container">
      <SectionHeader 
        eyebrow="Blog"
        heading="Insights & Strategy"
        description="Learn the strategies and tactics we use to drive results for our clients."
      />
      
      <div class="grid-3" id="blog-grid">
        {latestPosts.length > 0 ? (
          latestPosts.map((post, index) => {
            const publishDate = post.publishedAt 
              ? new Date(post.publishedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
              : '';
            
            return (
              <a href={`/blog/${post.slug.current}/`} class={`blog-card reveal${index > 0 ? ` reveal-delay-${index}` : ''}`}>
                <div class="blog-card-img-wrap">
                  {post.mainImage ? (
                    <img 
                      src={post.mainImage.asset.url}
                      alt={post.mainImage?.alt || post.title}
                      width="600"
                      height="180"
                      loading="lazy"
                      decoding="async"
                      class="blog-card-img"
                    />
                  ) : (
                    <div style="background:linear-gradient(135deg,var(--navy-700),var(--navy-500));display:flex;align-items:center;justify-content:center;height:100%">
                      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="1.5">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10 9 9 9 8 9"/>
                      </svg>
                    </div>
                  )}
                </div>
                <div class="blog-card-body">
                  <div class="blog-card-meta">
                    {post.categories && post.categories[0] && (
                      <span class="blog-card-cat">{post.categories[0].title}</span>
                    )}
                    {publishDate && (
                      <span class="blog-card-date">{publishDate}</span>
                    )}
                  </div>
                  <h3 class="blog-card-title">{post.title}</h3>
                  <p class="blog-card-excerpt">{post.excerpt}</p>
                  <span class="blog-read-more">Read Article</span>
                </div>
              </a>
            );
          })
        ) : (
          <div style="grid-column:1/-1;padding:var(--space-16);text-align:center;color:var(--mid-slate)">
            <p class="body-default">Articles loading from Sanity...</p>
          </div>
        )}
      </div>

      <div style="display:flex;justify-content:center;margin-top:var(--space-12)">
        <Button href="/blog" variant="secondary">View All Articles</Button>
      </div>
    </div>
  </section>

  <!-- =====================================================
       FAQ
       ===================================================== -->
  <section class="section bg-surface">
    <div class="container home-faq">
      <SectionHeader
        eyebrow="FAQ"
        heading="Questions, Answered"
        description="The things growing teams ask us most before starting a project."
      />
      <FAQAccordion faqs={faqs} />
    </div>
  </section>

  <!-- =====================================================
       CTA SECTION
       ===================================================== -->
  <CTASection
    eyebrow="Ready to Grow?"
    heading="Let's Build Your Digital Growth Engine"
    subtext="Book a discovery call and let's map out how strategy, design, development, and marketing can work together for your business."
    primaryBtn={{ text: "Book a Discovery Call", href: "/contact" }}
    secondaryBtn={{ text: "View Our Services", href: "/services" }}
  />

</Layout>

<style>
  /* Hero */
  .hero {
    background-color: var(--navy-500);
    padding-block: clamp(var(--space-20), 12vw, 8rem) var(--space-24);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 100% at 80% 0%, rgba(91, 170, 255, 0.14) 0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 20% 100%, rgba(255, 123, 53, 0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .hero-orb-1 {
    width: 420px;
    height: 420px;
    top: -160px;
    right: -80px;
    background: radial-gradient(circle, rgba(61, 148, 245, 0.35) 0%, transparent 70%);
  }

  .hero-orb-2 {
    width: 320px;
    height: 320px;
    bottom: -140px;
    left: -60px;
    background: radial-gradient(circle, rgba(255, 123, 53, 0.16) 0%, transparent 70%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 760px;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--sky-300);
    margin-bottom: var(--space-5);
    padding: var(--space-2) var(--space-4);
    border: 1px solid rgba(91, 170, 255, 0.3);
    border-radius: var(--radius-full);
    background-color: rgba(91, 170, 255, 0.06);
  }

  .hero-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--orange-300);
    flex-shrink: 0;
    box-shadow: 0 0 0 3px rgba(255, 123, 53, 0.2);
  }

  .hero-h1 {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: var(--tracking-tight);
    color: var(--white);
    margin-bottom: var(--space-6);
  }

  .hero-h1-accent {
    color: var(--orange-300);
    font-style: italic;
  }

  .hero-sub {
    font-size: var(--text-lg);
    color: var(--navy-100);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
    max-width: 560px;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-16);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    padding-top: var(--space-8);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .hero-stat-number {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--white);
    line-height: 1.1;
  }

  .hero-stat-label {
    font-size: var(--text-xs);
    color: var(--navy-200);
  }

  .hero-stat-divider {
    width: 1px;
    height: 32px;
    background-color: rgba(255, 255, 255, 0.15);
  }

  @media (max-width: 640px) {
    .hero-stat-divider { display: none; }
  }

  .hero-scroll-cue {
    position: absolute;
    left: 50%;
    bottom: var(--space-8);
    transform: translateX(-50%);
    color: var(--navy-100);
    opacity: 0.7;
    animation: bounceCue 2.2s var(--ease-in-out) infinite;
    z-index: 1;
  }

  .hero-scroll-cue:hover {
    color: var(--white);
    opacity: 1;
  }

  @keyframes bounceCue {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  @media (max-width: 768px) {
    .hero-scroll-cue { display: none; }
  }

  /* Client logo marquee */
  .marquee-wordmark {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--mid-slate);
    opacity: 0.55;
    white-space: nowrap;
    letter-spacing: 0.01em;
    transition: opacity var(--duration-base) var(--ease-out), color var(--duration-base) var(--ease-out);
  }

  .marquee-wordmark:hover {
    opacity: 1;
    color: var(--navy-500);
  }

  /* Service Cards */
  .service-card {
    background-color: var(--white);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-xl);
