---
// src/pages/contact.astro
// Contact — Zoho CRM web-to-contact form restyled to match the site design system
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const title = "Contact Us — Let's Talk About Your Project";
const description = "Get in touch with ZyrithTech to talk through your website, branding, or marketing project. We'll respond within one business day.";
const canonicalURL = "https://zyrithtech.com/contact/";
const ogImage = "https://zyrithtech.com/images/og-contact.jpg";

const infoItems = [
  {
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 6h18v12H3z" stroke-linejoin="round"/><path d="M3 7l9 6 9-6" stroke-linecap="round" stroke-linejoin="round"/></svg>',
    label: 'Email',
    value: 'info@zyrithtech.com',
    href: 'mailto:info@zyrithtech.com',
  },
];

const expectations = [
  'A reply within one business day',
  'A short discovery call to understand your goals',
  'A scoped proposal — no generic packages',
];

const faqs = [
  {
    question: 'How quickly will you respond after I get in touch?',
    answer: 'We reply within one business day. Your first message goes straight to our team — not a ticket queue — and we follow up to schedule a short discovery call at a time that works for you.',
  },
  {
    question: 'What happens after I submit the form?',
    answer: 'You will get a reply within one business day, followed by a discovery call to understand your goals. From there we send a scoped proposal tailored to your project — no generic packages and no obligation to proceed.',
  },
  {
    question: 'Is the discovery call free?',
    answer: 'Yes. The discovery call is free and carries no obligation. It is where we learn about your business and goals and work out whether we are the right partner — before any proposal or commitment.',
  },
  {
    question: 'What should I include in my message?',
    answer: 'A short note on your business, what you are trying to achieve (a new site, more leads, better branding), your rough timeline, and a link to your current site if you have one. Enough for us to make the first call useful.',
  },
  {
    question: 'Do you work with businesses outside India?',
    answer: 'Yes. We work with clients across India, the United States, the United Kingdom, Australia, and the Middle East. Projects run remotely with structured milestones and clear reporting, so location is never a barrier.',
  },
];
---

<Layout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
>
  <!-- =====================================================
       PAGE HEADER
       ===================================================== -->
  <section class="section bg-white contact-header">
    <div class="container">
      <Breadcrumb items={[{ label: 'Home', href: '/' }]} currentPage="Contact" />
      <div class="contact-header-content reveal">
        <span class="eyebrow contact-header-eyebrow">Get In Touch</span>
        <h1 class="section-h2 contact-header-heading">Let's Build Your Digital Growth Engine</h1>
        <p class="body-large contact-header-sub">Tell us a bit about your project and we'll get back to you within one business day to schedule a discovery call.</p>
      </div>
    </div>
  </section>

  <!-- =====================================================
       FORM + CONTACT INFO
       ===================================================== -->
  <section class="section bg-surface">
    <div class="container">
      <div class="contact-grid">
        <!-- Zoho CRM Web-to-Lead Form (restyled to site design system) -->
        <div class="contact-form-card reveal">
          <div id="crmWebToEntityForm" class="crmWebToEntityForm">
            <!-- Inline success notice — shown after AJAX submit succeeds, hidden again after 5s -->
            <div class="contact-success-toast" id="wf_splash" style="display:none">
              <svg class="contact-success-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <path d="M8 12l3 3 5-6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span id="wf_splash_info"></span>
            </div>

            <form
              id="webform1357533000000539001"
              name="WebToLeads1357533000000539001"
              accept-charset="UTF-8"
              class="contact-form"
            >
              <!-- Do not remove these hidden fields — required by Zoho for form submission -->
              <input type="text" style="display:none;" name="xnQsjsdp" value="a1b95aa23d2b556d136311d48bc64e2d4f91611cf0d264c4a984d8479d796fae" />
              <input type="hidden" name="zc_gad" id="zc_gad" value="" />
              <input type="text" style="display:none;" name="xmIwtLD" value="fc517fa3cab6404b30298fed5c7f10aab0ac59535855999e3e7de43692adac8a6d2bd505b1dec5e80f3216d9dc4cd05d" />
              <input type="text" style="display:none;" name="actionType" value="TGVhZHM=" />
              <input type="text" style="display:none;" name="returnURL" value="null" />

              <div class="form-group">
                <label class="form-label" for="Last_Name">Name <span class="form-required">*</span></label>
                <input type="text" id="Last_Name" class="form-input" aria-required="true" aria-label="Last Name" name="Last Name" maxlength="80" />
              </div>

              <div class="form-group">
                <label class="form-label" for="Email">Email <span class="form-required">*</span></label>
                <input type="text" ftype="email" autocomplete="off" id="Email" class="form-input" aria-required="true" aria-label="Email" name="Email" maxlength="100" />
              </div>

              <div class="form-group">
                <label class="form-label" for="Company">Company <span class="form-required">*</span></label>
                <input type="text" id="Company" class="form-input" aria-required="true" aria-label="Company" name="Company" maxlength="200" />
              </div>

              <div class="form-group">
                <label class="form-label" for="Phone">Phone</label>
                <input type="text" id="Phone" class="form-input" aria-required="false" aria-label="Phone" name="Phone" maxlength="30" />
              </div>

              <div class="form-group">
                <label class="form-label" for="Description">Message <span class="form-required">*</span></label>
                <textarea id="Description" class="form-input form-textarea" aria-multiline="true" aria-required="true" aria-label="Description" name="Description"></textarea>
              </div>

              <!-- Pre-set CRM fields, not shown to the visitor — mirrors Zoho's wfrm_fld_dpNn (hidden) row -->
              <div class="contact-form-hidden-field">
                <label for="Lead_Source">Lead Source</label>
                <select id="Lead_Source" onchange="addAriaSelected1357533000000539001()" aria-required="false" aria-label="Lead Source" name="Lead Source">
                  <option value="-None-">-None-</option>
                  <option value="Advertisement">Advertisement</option>
                  <option selected value="Website">Website</option>
                  <option value="Cold Call">Cold Call</option>
                  <option value="Employee Referral">Employee Referral</option>
                  <option value="External Referral">External Referral</option>
                  <option value="Online Store">Online Store</option>
                  <option value="Partner">Partner</option>
                  <option value="Public Relations">Public Relations</option>
                  <option value="Sales Email Alias">Sales Email Alias</option>
                  <option value="Seminar Partner">Seminar Partner</option>
                  <option value="Internal Seminar">Internal Seminar</option>
                  <option value="Trade Show">Trade Show</option>
                  <option value="Web Download">Web Download</option>
                  <option value="Web Research">Web Research</option>
                  <option value="Chat">Chat</option>
                  <option value="X (Twitter)">X (Twitter)</option>
                  <option value="Facebook">Facebook</option>
                </select>
              </div>
              <!-- Honeypot field — must stay type="text" + hidden via CSS so bots fill it in and get rejected server-side -->
              <input type="text" style="display:none;" name="aG9uZXlwb3Q" value="" tabindex="-1" autocomplete="off" />

              <div class="contact-form-actions">
                <button type="submit" id="formsubmit" class="formsubmit btn btn-primary btn-lg contact-submit" role="button" aria-label="Submit" title="Submit">
                  Send Message
                </button>
                <!-- name="reset" is required: the submit handler below calls form.reset.click() to clear fields on success -->
                <button type="reset" name="reset" class="btn btn-ghost btn-lg" role="button" aria-label="Reset" title="Reset">
                  Clear Form
                </button>
              </div>

              <p class="form-error" id="captchaErr1357533000000539001" style="visibility:hidden;"></p>

              <script>
                function addAriaSelected1357533000000539001(){
                  var optionElem = event.target;
                  var previousSelectedOption = optionElem.querySelector('[aria-selected=true]');
                  if (previousSelectedOption) {
                    previousSelectedOption.removeAttribute('aria-selected');
                  }
                  optionElem.querySelectorAll('option') [optionElem.selectedIndex] .ariaSelected = 'true';
                }
                function validateEmail1357533000000539001(){
                  var form = document.forms['WebToLeads1357533000000539001'];
                  var emailFld = form.querySelectorAll('[ftype=email]');
                  var i;
                  for(i = 0; i < emailFld.length; i++ ) {
                    var emailVal = emailFld[i].value;
                    if ((emailVal.replace (/^\s+|\s+$/g,'') ) .length != 0) {
                      var atpos = emailVal.indexOf('@');
                      var dotpos = emailVal.lastIndexOf('.');
                      if(atpos < 1 || dotpos < atpos + 2 || dotpos + 2 >= emailVal.length) {
                        alert('Please enter a valid email address. ');
                        emailFld[i].focus();
                        return false;
                      }
                    }
                  }
                  return true;
                }
                function checkMandatory1357533000000539001(isAjax){
                  var mndFileds = new Array('Company', 'Last Name', 'Email', 'Description');
                  var fldLangVal = new Array('Company', 'Name', 'Email', 'Message');
                  for (i = 0; i < mndFileds.length; i++ ) {
                    var fieldObj = document.forms['WebToLeads1357533000000539001'] [mndFileds[i]];
                    if (fieldObj) {
                      if(((fieldObj.value) .replace (/^\s+|\s+$/g,'') ) .length == 0) {
                        if (fieldObj.type == 'file') {
                          alert('Please select a file to upload.');
                          fieldObj.focus();
                          return false;
                        }
                        alert(fldLangVal[i] + ' cannot be empty.');
                        fieldObj.focus();
                        return false;
                      } else if (fieldObj.nodeName == 'SELECT') {
                        if (fieldObj.options[fieldObj.selectedIndex].value == '-None-') {
                          alert(fldLangVal[i] + ' cannot be none.');
                          fieldObj.focus();
                          return false;
                        }
                      } else if (fieldObj.type == 'checkbox') {
                        if (fieldObj.checked == false) {
                          alert('Please accept  ' + fldLangVal[i]);
                          fieldObj.focus();
                          return false;
                        }
                      }
                      try{
                        if (fieldObj.name == 'Last Name') {
                          name = fieldObj.value;
                        }
                      } catch (e){}
                    }
                  }
                  if ( !validateEmail1357533000000539001 () ) {
                    return false;
                  }
                  var urlparams = new URLSearchParams(window.location.search);
                  if (urlparams.has ('service') && (urlparams.get ('service') === 'smarturl') ) {
                    var webform = document.getElementById('webform1357533000000539001');
                    var service = urlparams.get('service');
                    var smarturlfield = document.createElement('input');
                    smarturlfield.setAttribute('type', 'hidden');
                    smarturlfield.setAttribute('value', service);
                    smarturlfield.setAttribute('name', 'service');
                    webform.appendChild(smarturlfield);
                  }
                  document.querySelector('.crmWebToEntityForm .formsubmit').setAttribute('disabled', true);
                }
                function captchaFailedHandling1357533000000539001(message){
                  var capErr = document.getElementById('captchaErr1357533000000539001');
                  capErr.innerHTML = message;
                  capErr.style.visibility = 'visible';
                  var capFld = document.getElementById('captchaField1357533000000539001');
                  if (capFld) { capFld.focus(); }
                  setTimeout(function(){
                    capErr.style.visibility = 'hidden';
                  },
                  5000);
                }
                document.getElementById('webform1357533000000539001').addEventListener('submit', function(e){
                  var ismandatory = checkMandatory1357533000000539001(true);
                  e.preventDefault();
                  if(ismandatory === undefined || ismandatory) {
                    if(typeof _wfa_track !== 'undefined' && _wfa_track.wfa_submit) {
                      _wfa_track.wfa_submit(e);
                    }
                    var formData = new FormData(this);
                    fetch('https://crm.zoho.in/crm/WebToLeadForm', {
                      method: 'POST',
                      body: formData,
                      cache: 'no-cache'
                    }).then(response => {
                      const contentType = response.headers.get('Content-Type');
                      return contentType.includes('application/json') ? response.json(): response.text();
                    }).then(data => {
                      if(typeof data === 'object') {
                        if(data.actionsubmit === 'Splash Message') {
                          if(data.invalidCaptcha && data.invalidCaptcha == 'true') {
                            captchaFailedHandling1357533000000539001(data.actionvalue);
                          } else {
                            if (typeof reloadImg1357533000000539001 !== 'undefined') {
                              reloadImg1357533000000539001();
                            }
                            var splashinfodom = document.getElementById('wf_splash_info');
                            splashinfodom.innerText = data.actionvalue;
                            var splashdom = document.getElementById('wf_splash');
                            if(splashinfodom) {
                              document.getElementById('webform1357533000000539001').reset.click();
                              splashdom.style.display = '';
                              setTimeout(function(){
                                splashdom.style.display = 'none';
                              },
                              5000);
                            }
                            if(typeof _wfa_track != 'undefined' && _wfa_track.wfa_post_submit) {
                              _wfa_track.wfa_post_submit(e);
                            }
                          }
                        } else if(data.actionsubmit === 'redirect_url' || data.actionsubmit === 'parent_redirect') {
                          if(data.success) {
                            if(typeof _wfa_track !== 'undefined' && _wfa_track.wfa_post_submit) {
                              _wfa_track.wfa_post_submit(e);
                            }
                            if (typeof historyBack1357533000000539001 !== 'undefined') {
                              window.addEventListener('focus', historyBack1357533000000539001);
                            }
                          }
                          if(data.actionsubmit === 'redirect_url') {
                            window.location.assign(data.redirectUrl);
                          } else if(data.actionsubmit === 'parent_redirect') {
                            parent.window.location = data.redirectUrl;
                          }
                        } else if(data.actionsubmit === 'parent_redirect') {
                          parent.window.location = data.redirectUrl;
                        } else if(data.actionsubmit === 'add_hash') {
                          document.location.hash = data.hash;
                        } else if(data.actionsubmit === 'error_msg') {
                          alert(data.message);
                        } else if(data.invalidCaptcha && data.invalidCaptcha === 'true') {
                          captchaFailedHandling1357533000000539001(data.actionvalue);
                          if(data.extraAction === 'parent_signal') {
                            window.parent.postMessage('checkCaptchaError', '*');
                          }
                        } else if(data.actionsubmit === 'captcha_error') {
                          alert(data.message);
                          if(data.extraAction === 'parent_signal') {
                            window.parent.postMessage('checkCaptchaError', '*');
                          }
                        } else if(data.actionsubmit === 'thankyou_page') {
                          if(typeof _wfa_track !== 'undefined' && _wfa_track.wfa_post_submit) {
                            _wfa_track.wfa_post_submit(e);
                            if (typeof historyBack1357533000000539001 !== 'undefined') {
                              window.addEventListener('focus', historyBack1357533000000539001);
                            }
                          }
                          window.location.assign(data.redirectUrl);
                        }
                      } else {
                        document.write(data);
                      }
                      let formDom = document.querySelector('.crmWebToEntityForm .formsubmit');
                      if (formDom) {
                        formDom.removeAttribute('disabled');
                      }
                    }).catch (error => {
                      alert('an error occurred');
                    });
                  }
                });
              </script>
              <!-- Do not remove this --- Analytics Tracking code starts -->
              <script id="wf_anal" src="https://crm.zohopublic.in/crm/WebFormAnalyticsServeServlet?&tw=bf14ed7855f373a8d54a8762651854150789a8c18a52396462c4e6a6e1f76d29"></script>
              <!-- Do not remove this --- Analytics Tracking code ends. -->
            </form>
          </div>
        </div>

        <!-- Contact Info Sidebar -->
        <div class="contact-info reveal reveal-delay-1">
          <div class="contact-info-card">
            <h3 class="card-h3 contact-info-heading">Contact Details</h3>
            {infoItems.map((item) => (
              <a href={item.href} class="contact-info-item">
                <span class="contact-info-icon" set:html={item.icon} />
                <span class="contact-info-text">
                  <span class="caption contact-info-label">{item.label}</span>
                  <span class="body-default contact-info-value">{item.value}</span>
                </span>
              </a>
            ))}
          </div>

          <div class="contact-info-card">
            <h3 class="card-h3 contact-info-heading">Prefer a Call?</h3>
            <p class="body-default contact-scheduler-copy">Book a quick call directly on our calendar — no back-and-forth emails.</p>
            <input id="buttonconfig" type="button" value="Schedule a Meeting" class="btn btn-primary contact-scheduler-btn" />
          </div>

          <div class="contact-info-card">
            <h3 class="card-h3 contact-info-heading">What Happens Next</h3>
            <ul class="contact-expectations">
              {expectations.map((item) => (
                <li class="contact-expectations-item">
                  <svg class="contact-expectations-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M8 12l3 3 5-6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span class="body-default">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- =====================================================
       FAQ
       ===================================================== -->
  <section class="section bg-surface">
    <div class="container contact-faq">
      <FAQAccordion title="Frequently Asked Questions" faqs={faqs} />
    </div>
  </section>

  <!-- Zoho Bookings "Schedule a Call" modal — triggered by #buttonconfig in the sidebar -->
  <div id="embed" class="contact-scheduler-overlay">
    <img
      src="https://static.zohocdn.com/crm/images/closeicon_59a5a09c5d664c355dbfcedb083c86a4_.png"
      class="contact-scheduler-close calBookingCloseIcn"
      alt="Close"
      onclick="document.getElementById('embed').getElementsByTagName('iframe')[0].remove(); document.getElementById('embed').style.display='none';document.getElementsByTagName('body')[0].style.overflow='';"
    />
  </div>

  <script>
    document.getElementById("buttonconfig").onclick = function () {
      renderIframe();
      document.getElementById("embed").style.display = "block";
    };

    function renderIframe() {
      document.getElementsByTagName("body")[0].style.overflow = "hidden";
      var url = 'https://crm.zoho.in/bookings/ScheduleaMeeting?rid=677a0f708de1aadf29eee162d7c3c2456807addeca0903d3ed2c2595997fc80c99a842a8b6882614bbfc9d6f65ac6f86gid941786215ddbf205c7b5c15a41c36fdd11a42a08e60e1ac23e3e4918a4bb25d9&option=embed';
      var JSElement = document.createElement("iframe");
      var width = "";
      var top = "";
      var height = "";
      if (window.innerWidth <= 480) {
        width = "98%";
        top = "16px";
        height = "min(720px, calc(100vh - 32px))";
      } else if (window.innerWidth <= 1024) {
        width = "92%";
        top = "24px";
        height = "min(720px, calc(100vh - 48px))";
      } else {
        width = "1100px";
        top = "48px";
        height = "min(760px, calc(100vh - 96px))";
      }
      JSElement.src = url;
      JSElement.setAttribute("style", "width:" + width + ";height:" + height + ";position: fixed; top:" + top + ";left:0;right:0;margin: 0 auto;background: #fff;border:1px solid #ddd;border-radius: 5px");
      document.getElementById("embed").appendChild(JSElement);
    }
  </script>
</Layout>

<style>
  .contact-header {
    padding-bottom: var(--space-8);
  }

  .contact-header-content {
    max-width: 720px;
  }

  .contact-header-eyebrow {
    color: var(--sky-500);
    margin-bottom: var(--space-3);
    display: block;
  }

  .contact-header-heading {
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
  }

  .contact-header-sub {
    color: var(--color-text-muted);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  .contact-form-card {
    background-color: var(--white);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    box-shadow: var(--shadow-sm);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .form-required {
    color: #D94F00;
  }

  .contact-form-hidden-field {
    display: none;
  }

  .contact-form-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-2);
    flex-wrap: wrap;
  }

  .contact-submit {
    border: none;
  }

  .contact-success-toast {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    position: fixed;
    top: var(--space-6);
    left: 50%;
    transform: translateX(-50%);
    max-width: 90%;
    width: max-content;
    z-index: 1000;
    padding: var(--space-3) var(--space-5);
    background-color: var(--white);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .contact-success-icon {
    flex-shrink: 0;
    color: var(--sky-500);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .contact-info-card {
    background-color: var(--white);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
  }

  .contact-info-heading {
    margin-bottom: var(--space-5);
  }

  .contact-info-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    text-decoration: none;
    color: inherit;
  }

  .contact-info-icon {
    flex-shrink: 0;
    color: var(--sky-500);
    margin-top: 2px;
  }

  .contact-info-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .contact-info-label {
    color: var(--color-text-muted);
  }

  .contact-info-value {
    color: var(--color-text-primary);
    font-weight: 600;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .contact-info-item:hover .contact-info-value {
    color: var(--sky-500);
  }

  .contact-expectations {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-expectations-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .contact-expectations-icon {
    flex-shrink: 0;
    color: var(--sky-500);
    margin-top: 2px;
  }

  .contact-scheduler-copy {
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }

  .contact-scheduler-btn {
    width: 100%;
    border: none;
    font-size: var(--text-sm);
  }

  .contact-scheduler-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.55);
    z-index: 1000;
  }

  .contact-scheduler-close {
    position: fixed;
    top: 64px;
    right: calc(50% - 550px + 8px);
    z-index: 1001;
    cursor: pointer;
    width: 32px;
    height: 32px;
    padding: 6px;
    background-color: var(--white);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-md);
