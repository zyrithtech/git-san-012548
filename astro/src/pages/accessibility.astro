---
// src/pages/accessibility.astro
// Accessibility Statement — legal content sourced from company-provided doc

import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const title = "Accessibility Statement";
const description = "Zyrith Technologies' commitment to digital accessibility, WCAG 2.1 AA conformance, and how to share accessibility feedback.";
const canonicalURL = "https://zyrithtech.com/accessibility/";

const features = [
  { label: 'Semantic HTML Structure', description: 'Proper use of headings, lists, and landmarks to facilitate navigation.' },
  { label: 'Alternative Text', description: 'Descriptive alt text for meaningful images to aid screen reader users.' },
  { label: 'Keyboard Navigation', description: 'Ensuring that all interactive elements are accessible via keyboard.' },
  { label: 'Color Contrast', description: 'Maintaining sufficient contrast between text and background to enhance readability.' },
  { label: 'Responsive Design', description: 'Optimizing the website for various devices and screen sizes.' },
];
---

<Layout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
>
  <!-- =====================================================
       PAGE HEADER
       ===================================================== -->
  <section class="section bg-white privacy-header">
    <div class="container">
      <Breadcrumb items={[{ label: 'Home', href: '/' }]} currentPage="Accessibility Statement" />
      <div class="privacy-header-content reveal">
        <span class="eyebrow privacy-header-eyebrow">Legal</span>
        <h1 class="section-h2 privacy-header-heading">Accessibility Statement</h1>
        <p class="body-large privacy-header-sub">Zyrith Technologies Pvt. Ltd.</p>
        <p class="caption privacy-header-date">Last updated: May 5, 2025</p>
      </div>
    </div>
  </section>

  <!-- =====================================================
       STATEMENT CONTENT
       ===================================================== -->
  <section class="section bg-surface">
    <div class="container privacy-content">
      <p class="body-default">
        At Zyrith Technologies, we are committed to ensuring digital accessibility for all users, including
        individuals with disabilities. We strive to continually enhance the user experience and apply
        relevant accessibility standards to achieve this goal.
      </p>

      <h2 class="card-h3 privacy-h2">Conformance Status</h2>
      <p class="body-default">
        We aim to conform to the Web Content Accessibility Guidelines (WCAG) 2.1 Level AA, which outline
        best practices for making web content more accessible to people with disabilities.
      </p>

      <h2 class="card-h3 privacy-h2">Accessibility Features</h2>
      <p class="body-default">Our website incorporates several features to improve accessibility:</p>
      <ul class="privacy-list">
        {features.map((feature) => (
          <li><strong>{feature.label}:</strong> {feature.description}</li>
        ))}
      </ul>

      <h2 class="card-h3 privacy-h2">Feedback</h2>
      <p class="body-default">
        We welcome your feedback on the accessibility of our website. If you encounter any barriers or
        have suggestions for improvement, please contact us at
        <a href="mailto:info@zyrithtech.com">info@zyrithtech.com</a>.
      </p>
      <p class="body-default">
        We aim to respond to accessibility feedback within 5-7 business days.
      </p>

      <h2 class="card-h3 privacy-h2">Ongoing Efforts</h2>
      <p class="body-default">
        Accessibility is an ongoing commitment. We conduct regular audits and engage with accessibility
        experts to identify and address potential issues. Our team receives training to stay informed
        about best practices and emerging standards.
      </p>
    </div>
  </section>
</Layout>

<style>
  .privacy-header {
    padding-bottom: var(--space-8);
  }

  .privacy-header-content {
    max-width: 720px;
  }

  .privacy-header-eyebrow {
    color: var(--sky-500);
    margin-bottom: var(--space-3);
    display: block;
  }

  .privacy-header-heading {
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .privacy-header-sub {
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .privacy-header-date {
    color: var(--color-text-muted);
  }

  .privacy-content {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .privacy-h2 {
    margin-top: var(--space-4);
  }

  .privacy-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-left: var(--space-6);
    list-style: disc;
    color: var(--color-text-body);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
  }

  .privacy-content a {
    color: var(--sky-500);
  }
</style>
