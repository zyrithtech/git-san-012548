---
// src/pages/work/[slug].astro
// Individual case study detail page

import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import CTASection from '../../components/CTASection.astro';
import { sanityImageUrl } from '../../lib/sanity';

export async function getStaticPaths() {
  const { getAllCaseStudies } = await import('../../lib/queries');
  const caseStudies = await getAllCaseStudies().catch(() => []);

  return caseStudies
    .filter((cs: any) => cs.slug?.current)
    .map((cs: any) => ({
      params: { slug: cs.slug.current },
      props: { caseStudy: cs, allCaseStudies: caseStudies },
    }));
}

const { caseStudy, allCaseStudies } = Astro.props;

const featuredImageUrl = caseStudy.featuredImage ? sanityImageUrl(caseStudy.featuredImage, 1400) : null;
const approachParagraphs: string[] = (caseStudy.approach || '').split('\n\n').filter(Boolean);
const otherCaseStudies = allCaseStudies
  .filter((cs: any) => cs.slug.current !== caseStudy.slug.current)
  .slice(0, 3);

const title = caseStudy.seo?.metaTitle || `${caseStudy.title} — Case Study`;
const description = caseStudy.seo?.metaDescription || `How ZyrithTech helped ${caseStudy.client} with ${(caseStudy.services || []).join(', ').toLowerCase()}.`;
const canonicalURL = `https://zyrithtech.com/work/${caseStudy.slug.current}/`;
const ogImage = caseStudy.seo?.ogImage ? sanityImageUrl(caseStudy.seo.ogImage, 1200) : (featuredImageUrl || "https://zyrithtech.com/images/og-work.jpg");
---

<Layout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CaseStudy',
    name: caseStudy.title,
    about: caseStudy.client,
    description,
  })} />

  <section class="section bg-white cs-header">
    <div class="container">
      <Breadcrumb
        items={[{ label: 'Home', href: '/' }, { label: 'Work', href: '/work' }]}
        currentPage={caseStudy.title}
      />

      <div class="cs-header-meta">
        {caseStudy.industry && <span class="eyebrow">{caseStudy.industry}</span>}
      </div>
      <h1 class="cs-title">{caseStudy.title}</h1>
      <p class="cs-client">Client: {caseStudy.client}</p>

      {caseStudy.services && caseStudy.services.length > 0 && (
        <div class="cs-tags">
          {caseStudy.services.map((service: string) => (
            <span class="cs-tag">{service}</span>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="cs-image-section">
    <div class="container">
      <div class="cs-image-wrap">
        {featuredImageUrl ? (
          <img
            src={featuredImageUrl}
            alt={caseStudy.title}
            width="1400"
            height="800"
            loading="eager"
            decoding="async"
          />
        ) : (
          <div class="cs-image-fallback">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1.5">
              <rect x="3" y="4" width="18" height="16" rx="2"/>
              <path d="M3 9h18M8 4v5" stroke-linecap="round"/>
            </svg>
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="section bg-white cs-content">
    <div class="container">
      <div class="cs-content-grid">
        <div class="cs-content-main">
          <div class="cs-block">
            <h2 class="section-h2">The Challenge</h2>
            <p class="body-large">{caseStudy.challenge}</p>
          </div>

          <div class="cs-block">
            <h2 class="section-h2">Our Approach</h2>
            {approachParagraphs.map((para) => (
              <p class="body-large">{para}</p>
            ))}
          </div>

          {caseStudy.testimonial && (
            <div class="cs-testimonial">
              <span class="quote-mark" aria-hidden="true">"</span>
              <p class="body-large cs-testimonial-quote">"{caseStudy.testimonial.quote}"</p>
              <div class="caption">— {caseStudy.testimonial.name}, {caseStudy.testimonial.role} at {caseStudy.testimonial.company}</div>
            </div>
          )}
        </div>

        {caseStudy.results && caseStudy.results.length > 0 && (
          <aside class="cs-sidebar">
            <h3 class="cs-sidebar-title">Results</h3>
            <div class="cs-results-list">
              {caseStudy.results.map((result: { metric: string; value: string; description: string }) => (
                <div class="cs-result">
                  <span class="cs-result-value">{result.value}</span>
                  <span class="cs-result-metric">{result.metric}</span>
                  <span class="cs-result-desc">{result.description}</span>
                </div>
              ))}
            </div>
          </aside>
        )}
      </div>

      {caseStudy.gallery && caseStudy.gallery.length > 0 && (
        <div class="cs-gallery">
          {caseStudy.gallery.map((image: any) => (
            <img
              src={sanityImageUrl(image, 800)}
              alt={image.alt || caseStudy.title}
              width="800"
              height="600"
              loading="lazy"
              decoding="async"
            />
          ))}
        </div>
      )}
    </div>
  </section>

  {otherCaseStudies.length > 0 && (
    <section class="section bg-surface">
      <div class="container">
        <h2 class="section-h2 cs-more-heading">Explore More Work</h2>
        <div class="grid-3">
          {otherCaseStudies.map((cs: any) => (
            <CaseStudyCard caseStudy={cs} />
          ))}
        </div>
      </div>
    </section>
  )}

  <CTASection
    eyebrow="Ready to Grow?"
    heading="Let's Build Your Digital Growth Engine"
    subtext="Book a discovery call and let's map out how strategy, design, development, and marketing can work together for your business."
    primaryBtn={{ text: "Book a Discovery Call", href: "/contact" }}
    secondaryBtn={{ text: "View Our Services", href: "/services" }}
  />
</Layout>

<style>
  .cs-header {
    padding-bottom: var(--space-10);
  }

  .cs-header-meta {
    margin-bottom: var(--space-3);
  }

  .cs-title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: 700;
    color: var(--navy-900);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-3);
  }

  .cs-client {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }

  .cs-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .cs-tag {
    font-size: var(--text-sm);
    color: var(--navy-500);
    background-color: var(--navy-50);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
  }

  .cs-image-section {
    padding-bottom: var(--space-16);
  }

  .cs-image-wrap {
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .cs-image-wrap img {
    width: 100%;
    height: auto;
    display: block;
  }

  .cs-image-fallback {
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--navy-700), var(--navy-500));
  }

  .cs-content-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--space-16);
    align-items: start;
  }

  @media (max-width: 900px) {
    .cs-content-grid {
      grid-template-columns: 1fr;
    }
  }

  .cs-content-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .cs-block .section-h2 {
    margin-bottom: var(--space-4);
  }

  .cs-block .body-large + .body-large {
    margin-top: var(--space-4);
  }

  .cs-testimonial {
    background-color: var(--navy-50);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
  }

  .cs-testimonial .quote-mark {
    font-size: 3rem;
    color: var(--sky-300);
    opacity: 0.5;
    font-family: var(--font-display);
    line-height: 1;
    margin-bottom: var(--space-2);
    display: block;
  }

  .cs-testimonial-quote {
    font-style: italic;
    margin-bottom: var(--space-4);
  }

  .cs-sidebar {
    position: sticky;
    top: calc(var(--nav-height) + var(--space-6));
    background-color: var(--white);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
  }

  .cs-sidebar-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--navy-900);
    margin-bottom: var(--space-6);
  }

  .cs-results-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .cs-result {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border-default);
  }

  .cs-result:first-child {
    padding-top: 0;
    border-top: none;
  }

  .cs-result-value {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--orange-300);
  }

  .cs-result-metric {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--navy-500);
  }

  .cs-result-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .cs-gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    margin-top: var(--space-16);
  }

  .cs-gallery img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
  }

  .cs-more-heading {
    margin-bottom: var(--space-10);
  }
</style>
