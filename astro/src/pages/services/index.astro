---
// src/pages/services/index.astro
// Services — top-level index linking to the three service pillars

import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ProcessStep from '../../components/ProcessStep.astro';
import ValueItem from '../../components/ValueItem.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { getFaqSection } from '../../lib/queries';
import CTASection from '../../components/CTASection.astro';

const categories = [
  {
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 8h18" stroke-linecap="round"/><path d="M9 21h6M12 18v3" stroke-linecap="round"/></svg>',
    title: 'Web Development',
    description: 'Conversion-focused websites, e-commerce, and ongoing hosting and maintenance — built on the platform that fits your team.',
    href: '/services/web-development',
    services: [
      { label: 'Website Design & Development', href: '/services/web-design-development/' },
      { label: 'E-commerce Solutions', href: '/services/ecommerce-solutions/' },
      { label: 'Website Hosting & Maintenance', href: '/services/website-maintenance/' },
    ],
  },
  {
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 20V4M4 20h16" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 16v-4M13 16V8M18 16v-7" stroke-linecap="round"/></svg>',
    title: 'Digital Marketing',
    description: 'SEO, content, social, paid, and email marketing run as one connected system — built to grow qualified leads, not just traffic.',
    href: '/services/digital-marketing',
    services: [
      { label: 'SEO', href: '/services/search-engine-optimization-seo/' },
      { label: 'Social Media Marketing', href: '/services/social-media-marketing/' },
      { label: 'PPC Advertising', href: '/services/ppc-advertising/' },
      { label: 'Email Marketing', href: '/services/email-marketing/' },
      { label: 'Content Marketing', href: '/services/content-marketing/' },
      { label: 'Analytics & Reporting', href: '/services/analytics-and-performance-reporting/' },
    ],
  },
  {
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/><path d="M9 12.5l2 2 4-4.5" stroke-linecap="round" stroke-linejoin="round"/></svg>',
    title: 'Creative & Branding',
    description: 'Logo, brand identity, and visual design systems built to stay consistent across your website, product, and marketing.',
    href: '/services/creative-branding',
    services: [
      { label: 'Graphic & Visual Design', href: '/services/graphic-visual-design/' },
      { label: 'Logo & Brand Identity', href: '/services/logo-and-brand-identity/' },
    ],
  },
];

const valueItems = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M15.5 8.5l-2 5-5 2 2-5 5-2z" stroke-linejoin="round"/></svg>',
    title: 'Strategy-First Approach',
    description: 'Every engagement starts with your positioning and goals, not a menu of services to choose from.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>',
    title: 'Platform-Agnostic Recommendations',
    description: 'We recommend the platform, channel mix, and design direction that fits your business, not what we default to.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.5-6 8-6s8 2 8 6" stroke-linecap="round" stroke-linejoin="round"/></svg>',
    title: 'One Team Across Every Discipline',
    description: 'Website, marketing, and brand work stay connected because one team owns all of it, not five vendors handing off.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 3L4 14h6l-1 7 9-11h-6l1-7z" stroke-linejoin="round"/></svg>',
    title: 'Focused on Business Outcomes',
    description: 'Every engagement is measured against leads, traffic, and conversions, not deliverables for their own sake.',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Discovery Call',
    description: 'Tell us about your business, goals, and challenges — no pitch, just questions to understand what you actually need.',
  },
  {
    number: '02',
    title: 'Requirements Assessment',
    description: 'We map which services actually fit your goals and budget, rather than defaulting to a fixed bundle.',
  },
  {
    number: '03',
    title: 'Proposal',
    description: 'A clear proposal covering scope, timeline, and investment — no vague packages or hidden line items.',
  },
  {
    number: '04',
    title: 'Kickoff',
    description: 'Work begins against agreed milestones, with one team accountable across every service involved.',
  },
];

const proofTags = ['Lead Growth', 'Organic Traffic Growth', 'Conversion Rate Improvements', 'Improved User Engagement'];

// Positioning comparison (grounded in the brand's differentiation — no invented
// numbers). Rendered as a real HTML table so answer engines can extract it.
const comparisonCols = ['ZyrithTech', 'Freelancer', 'In-house team', 'DIY builder'];
const comparisonRows = [
  { feature: 'Strategy before execution', values: ['Built into every engagement', 'Depends on the person', 'Only with senior hires', 'Not included'] },
  { feature: 'Design, development & marketing in one team', values: ['One accountable team', 'Usually one skill set', 'Several hires needed', 'You do it all'] },
  { feature: 'Single point of accountability', values: ['One team owns it', 'You coordinate vendors', 'You manage the team', 'You'] },
  { feature: 'Platform-agnostic (no lock-in)', values: ['Yes', 'Varies', 'Varies', 'Locked to the builder'] },
  { feature: 'Scales as your needs grow', values: ['Yes', 'Limited capacity', 'Slow, costly to scale', 'Limited'] },
  { feature: 'Reporting tied to leads & revenue', values: ['Yes', 'Rarely', 'Depends on the team', 'No'] },
];

const { sectionTitle, faqs } = await getFaqSection('services');

const title = "Digital Growth Services — Web, Marketing & Branding";
const description = "Web development, digital marketing, and creative branding run as one connected engagement, not five disconnected vendors. Book a discovery call.";
const canonicalURL = "https://www.zyrithtech.com/services/";
const ogImage = "https://www.zyrithtech.com/images/og-services.jpg";
---

<Layout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
>
  <!-- =====================================================
       PAGE HEADER
       ===================================================== -->
  <section class="section bg-white svc-header">
    <div class="container">
      <Breadcrumb items={[{ label: 'Home', href: '/' }]} currentPage="Services" />
      <div class="svc-header-content reveal">
        <span class="eyebrow svc-header-eyebrow">Services</span>
        <h1 class="section-h2 svc-header-heading">Strategy, Design, Development, and Marketing Under One Roof</h1>
        <p class="body-large svc-header-sub">Zyrith combines web development, creative and branding, and digital marketing into one connected engagement — so you work with a single accountable partner instead of five disconnected vendors.</p>
      </div>
    </div>
  </section>

  <!-- =====================================================
       SERVICE CATEGORIES
       ===================================================== -->
  <section class="section bg-surface">
    <div class="container">
      <SectionHeader
        eyebrow="What We Do"
        heading="Three Disciplines, One Accountable Team"
        description="Explore each area below, or book a discovery call and we'll map the services that actually fit your goals."
      />
      <div class="category-grid">
        {categories.map((category, index) => (
          <div class={`category-card reveal reveal-delay-${index + 1}`}>
            <div class="category-card-icon" aria-hidden="true" set:html={category.icon} />
            <h3 class="category-card-title">
              <a href={category.href}>{category.title}</a>
            </h3>
            <p class="category-card-desc">{category.description}</p>
            <ul class="category-card-services">
              {category.services.map((service) => (
                <li>
                  <a href={service.href}>{service.label}</a>
                </li>
              ))}
            </ul>
            <a href={category.href} class="category-card-link">Explore {category.title} &rarr;</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- =====================================================
       HOW WE WORK TOGETHER
       ===================================================== -->
  <section class="section bg-white">
    <div class="container">
      <SectionHeader
        eyebrow="Our Process"
        heading="How We Work Together"
        description="The same discovery-led process, whether you're starting with one service or several."
      />
      <div class="grid-4">
        {processSteps.map((step, index) => (
          <ProcessStep
            number={step.number}
            title={step.title}
            description={step.description}
            delay={index as 0 | 1 | 2 | 3}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- =====================================================
       WHY ONE PARTNER (VALUE BAND)
       ===================================================== -->
  <section class="value-band">
    <div class="container">
      <SectionHeader
        eyebrow="Why One Partner"
        heading="One Team, Accountable Across Every Discipline"
        description="Strategy, execution, and reporting stay connected because one team owns all of it — not five vendors handing off between channels."
        variant="light"
      />
      <div class="value-grid">
        {valueItems.map((item, index) => (
          <ValueItem
            icon={item.icon}
            title={item.title}
            description={item.description}
            delay={index as 0 | 1 | 2 | 3}
            variant="dark"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- =====================================================
       HOW WE COMPARE
       ===================================================== -->
  <section class="section bg-white">
    <div class="container">
      <SectionHeader
        eyebrow="How We Compare"
        heading="One Partner vs. the Alternatives"
        description="How working with one accountable agency compares to a freelancer, an in-house team, or a DIY website builder."
      />
      <div class="compare-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th scope="col">What matters</th>
              {comparisonCols.map((c, i) => (
                <th scope="col" class={i === 0 ? 'compare-primary' : ''}>{c}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row) => (
              <tr>
                <th scope="row">{row.feature}</th>
                {row.values.map((v, i) => (
                  <td class={i === 0 ? 'compare-primary' : ''}>{v}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- =====================================================
       PROOF / CASE STUDIES TEASE
       ===================================================== -->
  <section class="section bg-white">
    <div class="container proof-section">
      <SectionHeader
        eyebrow="Proof"
        heading="Engagements We Measure Against Agreed Metrics"
        description="Every engagement is reported against the numbers that matter to your business — not deliverables for their own sake."
      />
      <div class="proof-tags reveal reveal-delay-1">
        {proofTags.map((tag) => (
          <span class="proof-tag">{tag}</span>
        ))}
      </div>
      <div class="proof-cta reveal reveal-delay-2">
        <a href="/portfolio" class="btn btn-secondary">See Case Studies</a>
      </div>
    </div>
  </section>

  <!-- =====================================================
       FAQ
       ===================================================== -->
  <section class="section bg-surface">
    <div class="container svc-faq">
      <FAQAccordion title={sectionTitle} faqs={faqs} />
    </div>
  </section>

  <!-- =====================================================
       CTA SECTION
       ===================================================== -->
  <CTASection
    eyebrow="Ready to Grow?"
    heading="Ready to Build Your Digital Growth Plan?"
    subtext="Book a discovery call and we'll map the services that actually fit your goals — no fixed package pitch."
    primaryBtn={{ text: "Book a Discovery Call", href: "/contact" }}
    secondaryBtn={{ text: "See Case Studies", href: "/portfolio" }}
  />
</Layout>

<style>
  .svc-header {
    padding-bottom: var(--space-8);
  }

  .svc-header-content {
    max-width: 720px;
  }

  .svc-header-eyebrow {
    color: var(--sky-500);
    margin-bottom: var(--space-3);
    display: block;
  }

  .svc-header-heading {
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
  }

  .svc-header-sub {
    color: var(--color-text-muted);
  }

  /* Category cards */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  @media (max-width: 1024px) {
    .category-grid {
      grid-template-columns: 1fr;
      max-width: 560px;
      margin-inline: auto;
    }
  }

  .category-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-8);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-xl);
    background-color: var(--white);
    transition: border-color var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out),
                transform var(--duration-base) var(--ease-out);
  }

  .category-card:hover {
    border-color: var(--sky-300);
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  .category-card-icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    background-color: var(--sky-50);
    color: var(--sky-500);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .category-card-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: var(--leading-snug);
  }

  .category-card-title a {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .category-card-title a:hover {
    color: var(--sky-500);
  }

  .category-card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .category-card-services {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    list-style: none;
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border-default);
    flex-grow: 1;
  }

  .category-card-services a {
    font-size: var(--text-sm);
    color: var(--color-text-body);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .category-card-services a:hover {
    color: var(--sky-500);
    text-decoration: underline;
  }

  .category-card-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--sky-500);
    text-decoration: none;
  }

  .category-card-link:hover {
    text-decoration: underline;
  }

  /* Proof section */
  .proof-section {
    text-align: center;
  }

  .proof-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
    margin-top: calc(var(--space-16) * -1 + var(--space-6));
    margin-bottom: var(--space-8);
  }

  .proof-tag {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-5);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--navy-500);
    background-color: var(--sky-50);
  }

  .proof-cta {
    display: flex;
    justify-content: center;
  }

  .svc-faq {
    max-width: 760px;
  }

  /* Comparison table */
  .compare-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-xl);
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 720px;
    font-size: var(--text-sm);
  }

  .compare-table th,
  .compare-table td {
    text-align: left;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--color-border-default);
    vertical-align: top;
  }

  .compare-table thead th {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--navy-900);
    background-color: var(--sky-50);
    white-space: nowrap;
  }

  .compare-table tbody th {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .compare-table tbody td {
    color: var(--color-text-body);
  }

  .compare-table tbody tr:last-child th,
  .compare-table tbody tr:last-child td {
    border-bottom: none;
  }

  .compare-table .compare-primary {
    background-color: var(--navy-50);
    color: var(--navy-900);
    font-weight: 600;
  }

  .compare-table thead .compare-primary {
    background-color: var(--navy-500);
    color: var(--white);
  }
</style>
