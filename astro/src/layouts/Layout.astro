---
// src/layouts/Layout.astro
// Main layout wrapper — shared across all pages
// Includes: Nav + Footer + global meta tags + global JavaScript

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
}

const { 
  title, 
  description = "ZyrithTech — Digital marketing, web development, and brand identity agency for startups and SMBs",
  canonicalURL = "https://zyrithtech.com/",
  ogImage = "/images/og-default.jpg"
} = Astro.props;

const siteName = "ZyrithTech";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | {siteName}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonicalURL}>
  
  <!-- Open Graph / Social Media -->
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content={siteName}>
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" href="/favicon.png">
</head>

<body>
  <!-- Navigation -->
  <Nav />
  
  <!-- Main Content -->
  <main id="main-content">
    <slot />
  </main>

  <!-- Footer -->
  <Footer />

  <!-- ============================================================
    GLOBAL JAVASCRIPT
    Handles: nav scroll state, hamburger toggle, scroll reveal
    ============================================================ -->
  <script defer>
    // ── NAV SCROLL STATE ──
    // Adds .is-scrolled class to nav when scrolling down
    const nav = document.querySelector('.nav');
    const scrollThreshold = 20;

    const updateNav = () => {
      if (window.scrollY > scrollThreshold) {
        nav?.classList.add('is-scrolled');
      } else {
        nav?.classList.remove('is-scrolled');
      }
    };

    window.addEventListener('scroll', updateNav, { passive: true });
    updateNav();

    // ── HAMBURGER MENU TOGGLE ──
    const hamburger = document.querySelector('.nav__hamburger');
    const drawer = document.querySelector('[role="dialog"]');

    if (hamburger && drawer) {
      hamburger.addEventListener('click', () => {
        const isActive = hamburger.classList.toggle('is-active');
        drawer.setAttribute('aria-hidden', String(!isActive));
        document.body.style.overflow = isActive ? 'hidden' : '';
        hamburger.setAttribute('aria-expanded', String(isActive));
      });

      // Close drawer on escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && hamburger.classList.contains('is-active')) {
          hamburger.classList.remove('is-active');
          drawer.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
          hamburger.setAttribute('aria-expanded', 'false');
        }
      });

      // Close drawer when clicking outside
      drawer.addEventListener('click', (e) => {
        if (e.target === drawer) {
          hamburger.classList.remove('is-active');
          drawer.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
          hamburger.setAttribute('aria-expanded', 'false');
        }
      });
    }

    // ── SCROLL REVEAL (IntersectionObserver) ──
    // Adds .visible class to elements with .reveal when they come into view
    if ('IntersectionObserver' in window) {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.1,
          rootMargin: '0px 0px -40px 0px'
        }
      );

      // Observe all .reveal elements
      document.querySelectorAll('.reveal').forEach((el) => {
        revealObserver.observe(el);
      });
    }

    // ── FOOTER YEAR ──
    // Dynamically update copyright year
    const footerYear = document.querySelector('[data-year]');
    if (footerYear) {
      footerYear.textContent = new Date().getFullYear().toString();
    }
  </script>
</body>
</html>

<style is:global>
  /* ── Nav scroll state styling ── */
  .nav.is-scrolled {
    background-color: var(--white);
    box-shadow: var(--shadow-nav);
  }

  .nav.is-scrolled .nav__logo {
    color: var(--navy-500);
  }

  .nav.is-scrolled .nav__link {
    color: var(--dark-slate);
  }

  /* Ensure main content respects full viewport */
  html, body {
    height: 100%;
  }

  #main-content {
    min-height: calc(100vh - var(--nav-height));
  }
</style>
