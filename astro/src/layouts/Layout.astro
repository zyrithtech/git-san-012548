---
// src/layouts/Layout.astro
// Main layout wrapper — shared across all pages
// Includes: Nav + Footer + global meta tags + global JavaScript

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
  ogType?: string;
  publishedTime?: string;
}

const {
  title,
  description = "ZyrithTech — a digital growth partner for startups, SMBs, and professional service firms. Website development, branding, SEO, and marketing under one accountable team.",
  canonicalURL,
  ogImage = "/images/og-default.jpg",
  ogType = "website",
  publishedTime,
} = Astro.props;

const siteName = "ZyrithTech";
const SITE = "https://zyrithtech.com";

// Default canonical to the current page URL (safety net) instead of the
// homepage, so a page that forgets to pass canonicalURL still self-canonicals.
const canonical = canonicalURL || new URL(Astro.url.pathname, SITE).href;
// Social scrapers want an absolute og:image URL.
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `${SITE}${ogImage}`;

// Measurement / verification — set these as Netlify env vars (PUBLIC_ prefix so
// they're exposed to the client build). Nothing renders until they're provided,
// so there are no secrets in the repo and no broken tags.
const GA_ID = import.meta.env.PUBLIC_GA_ID;
const GSC_VERIFICATION = import.meta.env.PUBLIC_GSC_VERIFICATION;

// ─────────────────────────────────────────────────────────────
// Sitewide entity graph — rendered on EVERY page.
// Organization is merged with ProfessionalService (the local-business subtype)
// so one node feeds both knowledge-graph and local signals. Other templates'
// Article / Service / Breadcrumb schema reference these via @id
// (#organization / #website), so keep those ids stable.
// ─────────────────────────────────────────────────────────────
const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["Organization", "ProfessionalService"],
      "@id": `${SITE}/#organization`,
      "name": "ZyrithTech",
      "legalName": "Zyrith Technologies Pvt. Ltd.",
      "url": `${SITE}/`,
      "logo": {
        "@type": "ImageObject",
        "@id": `${SITE}/#logo`,
        "url": `${SITE}/images/logo.svg`,
        "caption": "ZyrithTech",
      },
      "image": { "@id": `${SITE}/#logo` },
      "description":
        "ZyrithTech (Zyrith Technologies) is a digital growth partner for startups, SMBs, and professional service firms — website development, branding, SEO, and digital marketing under one accountable team.",
      "email": "info@zyrithtech.com",
      "telephone": "+91-9910788808",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "B1-1404, SVD, Raj Nagar Extension",
        "addressLocality": "Ghaziabad",
        "addressRegion": "Uttar Pradesh",
        "postalCode": "201017",
        "addressCountry": "IN",
      },
      "areaServed": [
        { "@type": "Country", "name": "India" },
        { "@type": "Country", "name": "United States" },
        { "@type": "Country", "name": "United Kingdom" },
        { "@type": "Country", "name": "Australia" },
        { "@type": "Place", "name": "Middle East" },
      ],
      "knowsAbout": [
        "Website development",
        "E-commerce development",
        "Search engine optimization",
        "Digital marketing",
        "Brand identity design",
        "UI/UX design",
        "Content marketing",
        "PPC advertising",
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "info@zyrithtech.com",
        "telephone": "+91-9910788808",
        "contactType": "sales",
        "availableLanguage": ["English"],
        "areaServed": ["IN", "US", "GB", "AU"],
      },
      "sameAs": [
        "https://www.linkedin.com/company/zyrithtech",
        "https://twitter.com/zyrithtech",
        "https://www.instagram.com/zyrithtech",
      ],
      "founder": {
        "@type": "Person",
        "@id": `${SITE}/#person-kishore-k`,
        "name": "Kishore K.",
        "jobTitle": "Founder",
        "sameAs": ["https://www.linkedin.com/in/kishore-zyrithtech/"],
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "ZyrithTech Services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Digital Marketing", "url": `${SITE}/services/digital-marketing` } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Web Development", "url": `${SITE}/services/web-development` } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Creative & Branding", "url": `${SITE}/services/creative-branding` } },
        ],
      },
    },
    {
      "@type": "WebSite",
      "@id": `${SITE}/#website`,
      "url": `${SITE}/`,
      "name": "ZyrithTech",
      "description":
        "Website development, branding, SEO, and digital marketing under one accountable team.",
      "publisher": { "@id": `${SITE}/#organization` },
      "inLanguage": "en",
    },
  ],
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {/* Google Search Console verification (set PUBLIC_GSC_VERIFICATION) */}
  {GSC_VERIFICATION && <meta name="google-site-verification" content={GSC_VERIFICATION} />}

  {/* Google Analytics 4 (set PUBLIC_GA_ID, e.g. G-XXXXXXXXXX) */}
  {GA_ID && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
      <script is:inline define:vars={{ GA_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', GA_ID);
      </script>
    </>
  )}

  <title>{title} | {siteName}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonical}>

  <!-- Open Graph / Social Media -->
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImageAbsolute}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:url" content={canonical}>
  <meta property="og:type" content={ogType}>
  <meta property="og:site_name" content={siteName}>
  {ogType === 'article' && publishedTime && (
    <meta property="article:published_time" content={publishedTime} />
  )}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImageAbsolute}>

  <!-- Fonts — Fontshare CDN (Hind headings + Amulya body). Loaded non-render-
       blocking via preload+swap; the sans-serif fallbacks in global.css render
       instantly and are replaced when the font stylesheet arrives. -->
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin>
  <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin>
  <link
    rel="preload"
    as="style"
    href="https://api.fontshare.com/v2/css?f[]=amulya@400&f[]=hind@700&display=swap"
    onload="this.onload=null;this.rel='stylesheet'"
  >
  <noscript>
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=amulya@400&f[]=hind@700&display=swap"
    >
  </noscript>

  <!-- Favicon -->
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">

  <!-- Sitewide entity graph: Organization / ProfessionalService + WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
</head>

<body>
  <!-- Navigation -->
  <Nav />
  
  <!-- Main Content -->
  <main id="main-content">
    <slot />
  </main>

  <!-- Footer -->
  <Footer />

  <!-- ============================================================
    GLOBAL JAVASCRIPT
    Handles: scroll reveal
    Nav scroll state, hamburger toggle, and footer year are handled by
    Nav.astro and Footer.astro's own inline scripts — kept here previously
    but targeted class names (.nav__hamburger, [role="dialog"], [data-year])
    that don't exist in that markup, so they never ran.
    ============================================================ -->
  <script defer>
    // ── SCROLL REVEAL (IntersectionObserver) ──
    // Adds .visible class to elements with .reveal when they come into view
    if ('IntersectionObserver' in window) {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.1,
          rootMargin: '0px 0px -40px 0px'
        }
      );

      // Observe all .reveal elements
      document.querySelectorAll('.reveal').forEach((el) => {
        revealObserver.observe(el);
      });
    }
  </script>
</body>
</html>

<style is:global>
  /* Ensure main content respects full viewport */
  html, body {
    height: 100%;
  }

  #main-content {
    min-height: calc(100vh - var(--nav-height));
  }
</style>
