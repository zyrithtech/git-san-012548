---
// src/components/Footer.astro
// Footer — company info, navigation, social links, legal
import logo from '../assets/logo_light-text.svg';

const currentYear = new Date().getFullYear();

const footerLinks = {
  Services: [
    { label: 'Digital Marketing', href: '/services/digital-marketing' },
    { label: 'Web Development', href: '/services/web-development' },
    { label: 'Branding & Design', href: '/services/creative-branding' },
    { label: 'See All Services', href: '/services' },
  ],
  Company: [
    { label: 'About Us', href: '/about-us' },
    { label: 'Case Studies', href: '/portfolio' },
    { label: 'Blog', href: '/blog' },
    { label: 'Contact', href: '/contact' },
  ],
};

const socialLinks = [
  { 
    name: 'LinkedIn', 
    href: 'https://linkedin.com/company/zyrithtech',
    icon: 'linkedin'
  },
  { 
    name: 'Twitter', 
    href: 'https://twitter.com/zyrithtech',
    icon: 'twitter'
  },
  { 
    name: 'Instagram', 
    href: 'https://instagram.com/zyrithtech',
    icon: 'instagram'
  },
];
---

<footer class="footer">
  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">
        <!-- Brand Section -->
        <div class="footer-brand">
          <div class="footer-logo">
            <img src={logo.src} width="164" height="56" alt="ZyrithTech" class="footer-logo-img" />
          </div>
          <p class="footer-tagline">
            Digital growth partner for startups, SMBs, and professional service firms. We build conversion-focused websites, brand systems, and SEO-driven marketing that turn your digital presence into a consistent inquiry pipeline.
          </p>

          <!-- NAP (name / address / phone) — kept in sync with the
               Organization schema in Layout.astro for local-SEO consistency. -->
          <address class="footer-contact">
            <span class="footer-contact-name">Zyrith Technologies Pvt. Ltd.</span>
            <span class="footer-contact-line">B1-1404, SVD, Raj Nagar Extension,<br />Ghaziabad, Uttar Pradesh 201017, India</span>
            <a href="tel:+919910788808" class="footer-contact-link">+91 99107 88808</a>
            <a href="mailto:info@zyrithtech.com" class="footer-contact-link">info@zyrithtech.com</a>
          </address>

          <div class="footer-socials">
            {socialLinks.map((social) => (
              <a 
                href={social.href} 
                target="_blank" 
                rel="noopener noreferrer"
                class="footer-social-link"
                aria-label={social.name}
                title={social.name}
              >
                {social.icon === 'linkedin' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.475-2.236-1.667-2.236-1.062 0-1.716.723-2 1.423-.044.148-.14.462-.14 1.06v5.322h-3.552v-9h3.552v1.227h.049c.537-.91 1.752-1.86 3.628-1.86 2.75 0 4.827 1.797 4.827 5.661v4.972zM5.337 9.432a2.063 2.063 0 1 1 0-4.126 2.063 2.063 0 0 1 0 4.126zm1.782 11.02H3.555v-9h3.564v9zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                )}
                {social.icon === 'twitter' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                  </svg>
                )}
                {social.icon === 'instagram' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678a6.162 6.162 0 100 12.324 6.162 6.162 0 100-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm7.846-10.405a1.441 1.441 0 01-2.88 0 1.44 1.44 0 012.88 0z"/>
                  </svg>
                )}
              </a>
            ))}
          </div>
        </div>

        <!-- Navigation Links -->
        {Object.entries(footerLinks).map(([category, links]) => (
          <div class="footer-column">
            <h3 class="footer-column-title">{category}</h3>
            <ul class="footer-links-list">
              {links.map((link) => (
                <li>
                  <a href={link.href} class="footer-link">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Footer Bottom -->
  <div class="footer-bottom">
    <div class="container">
      <div class="footer-bottom-content">
        <p class="footer-copyright">
          &copy; <span id="footer-year">{currentYear}</span> ZyrithTech. All rights reserved.
        </p>
        <div class="footer-bottom-links">
          <a href="/privacy-policy" class="footer-bottom-link">Privacy Policy</a>
          <span class="footer-bottom-sep">·</span>
          <a href="/accessibility" class="footer-bottom-link">Accessibility Statement</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* ===============================
     FOOTER MAIN
     =============================== */
  .footer {
    background-color: var(--navy-900);
    color: var(--navy-100);
    margin-top: auto;
  }

  .footer-main {
    padding-block: var(--space-24);
    border-bottom: 1px solid var(--navy-700);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-12);
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }

  /* ===============================
     BRAND SECTION
     =============================== */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .footer-logo-img {
    height: 38px;
    width: auto;
  }

  .footer-tagline {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--navy-200);
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-style: normal; /* reset <address> italic */
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--navy-200);
  }

  .footer-contact-name {
    font-weight: 600;
    color: var(--navy-100);
  }

  .footer-contact-link {
    color: var(--navy-200);
    text-decoration: none;
    width: fit-content;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-contact-link:hover {
    color: var(--sky-300);
  }

  .footer-socials {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .footer-social-link {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.05);
    color: var(--sky-300);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color var(--duration-base) var(--ease-out),
                color var(--duration-base) var(--ease-out);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-social-link:hover {
    background-color: var(--sky-300);
    color: var(--navy-900);
  }

  /* ===============================
     FOOTER COLUMNS
     =============================== */
  .footer-column {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer-column-title {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--white);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  .footer-links-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
  }

  .footer-link {
    font-size: var(--text-sm);
    color: var(--navy-200);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-link:hover {
    color: var(--sky-300);
  }

  /* ===============================
     FOOTER BOTTOM
     =============================== */
  .footer-bottom {
    background-color: var(--navy-900);
    padding-block: var(--space-6);
    border-top: 1px solid var(--navy-700);
  }

  .footer-bottom-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  @media (max-width: 640px) {
    .footer-bottom-content {
      flex-direction: column;
      text-align: center;
    }
  }

  .footer-copyright {
    font-size: var(--text-xs);
    /* navy-300 on navy-900 is only 2:1 — navy-200 clears 4.5:1 */
    color: var(--navy-200);
  }

  .footer-bottom-links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .footer-bottom-link {
    font-size: var(--text-xs);
    color: var(--navy-200);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-bottom-link:hover {
    color: var(--sky-300);
  }

  .footer-bottom-sep {
    color: var(--navy-700);
  }

  /* ===============================
     ACCESSIBILITY
     =============================== */
  @media (prefers-reduced-motion: reduce) {
    .footer-social-link,
    .footer-link,
    .footer-contact-link {
      transition: none;
    }
  }
</style>

<script>
  // Update copyright year dynamically
  const yearElement = document.getElementById('footer-year');
  if (yearElement) {
    yearElement.textContent = new Date().getFullYear().toString();
  }
</script>
