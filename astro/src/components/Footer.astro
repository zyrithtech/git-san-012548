---
// src/components/Footer.astro
// Footer — company info, navigation, social links, legal
import logo from '../assets/logo_light-text.svg';

const currentYear = new Date().getFullYear();

const footerLinks = {
  Services: [
    { label: 'Digital Marketing', href: '/services/digital-marketing' },
    { label: 'Web Development', href: '/services/web-development' },
    { label: 'Branding & Design', href: '/services/creative-branding' },
    { label: 'See All Services', href: '/services' },
  ],
  Company: [
    { label: 'About Us', href: '/about-us' },
    { label: 'Case Studies', href: '/portfolio' },
    { label: 'Blog', href: '/blog' },
    { label: 'Contact', href: '/contact' },
  ],
};

const socialLinks = [
  { 
    name: 'LinkedIn', 
    href: 'https://linkedin.com/company/zyrithtech',
    icon: 'linkedin'
  },
  { 
    name: 'Twitter', 
    href: 'https://twitter.com/zyrithtech',
    icon: 'twitter'
  },
  { 
    name: 'Instagram', 
    href: 'https://instagram.com/zyrithtech',
    icon: 'instagram'
  },
];
---

<footer class="footer">
  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">
        <!-- Brand Section -->
        <div class="footer-brand">
          <div class="footer-logo">
            <img src={logo.src} width="164" height="56" alt="ZyrithTech" class="footer-logo-img" />
          </div>
          <p class="footer-tagline">
            Digital growth partner for startups, SMBs, and professional service firms. We build conversion-focused websites, brand systems, and SEO-driven marketing that turn your digital presence into a consistent inquiry pipeline.
          </p>

          <!-- NAP (name / address / phone) — kept in sync with the
               Organization schema in Layout.astro for local-SEO consistency. -->
          <address class="footer-contact">
            <span class="footer-contact-name">Zyrith Technologies Pvt. Ltd.</span>
            <span class="footer-contact-line">B1-1404, SVD, Raj Nagar Extension,<br />Ghaziabad, Uttar Pradesh 201017, India</span>
            <a href="tel:+919910788808" class="footer-contact-link">+91 99107 88808</a>
            <a href="mailto:info@zyrithtech.com" class="footer-contact-link">info@zyrithtech.com</a>
          </address>

          <div class="footer-socials">
            {socialLinks.map((social) => (
              <a 
                href={social.href} 
                target="_blank" 
                rel="noopener noreferrer"
                class="footer-social-link"
                aria-label={social.name}
                title={social.name}
              >
                {social.icon === 'linkedin' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.475-2.236-1.667-2.236-1.062 0-1.716.723-2 1.423-.044.148-.14.462-.14 1.06v5.322h-3.552v-9h3.552v1.227h.049c.537-.91 1.752-1.86 3.628-1.86 2.75 0 4.827 1.797 4.827 5.661v4.972zM5.337 9.432a2.063 2.063 0 1 1 0-4.126 2.063 2.063 0 0 1 0 4.126zm1.782 11.02H3.555v-9h3.564v9zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                )}
                {social.icon === 'twitter' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M23.953 4.57a10 10 0 002.856-3.486 10.023 10.023 0 01-2.856.856c1.022-.64 1.8-1.656 2.169-2.863a10.022 10.022 0 01-3.142 1.194c-.948-1.045-2.318-1.694-3.807-1.694-2.882 0-5.217 2.334-5.217 5.217 0 .408.046.81.138 1.201a14.922 14.922 0 01-10.85-5.482c-.397.672-.621 1.45-.621 2.28C.553 7.528 2.004 9.457 4.002 10.3a5.214 5.214 0 01-2.353-.646v.066c0 2.51 1.787 4.605 4.182 5.074a5.209 5.209 0 01-2.357.09c.667 2.067 2.614 3.57 4.91 3.612a10.447 10.447 0 01-6.433 2.217A14.88 14.88 0 008 21.54a14.836 14.836 0 008.054 2.46c9.665 0 14.921-8.017 14.921-14.922 0-.227-.005-.453-.015-.678a10.623 10.623 0 002.606-2.712l.002-.002z"/>
                  </svg>
                )}
                {social.icon === 'instagram' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.521 17.34c-.24.65-.045 1.85-.5 1.955-.675.092-1.24.027-1.614-.317-.88.032-1.78.216-2.433.542-.645.324-.953.845-1.135 1.592-.099.46-.173.946-.016 1.49.054.576.326.922.596 1.427.12.205.21.436.21.672 0 .794-.635 1.467-1.479 1.467-.955 0-1.556-.635-1.556-1.4 0-.238.061-.513.154-.747-.091-.3-.3-.919-.672-1.654-.31.142-1.49.023-1.490-.205v-.122c.503-.574 1.397-1.207 2.01-1.696a4.536 4.536 0 001.659-1.064c.418-.515.872-1.268.821-2.042-.03-.follower-.248-.868-.572-1.21-.296-.31-.515-.643-.515-.983 0-.563.26-1.06.674-1.316.31-.183.646-.298 1.004-.331.356.331.706.66.95.959.23.276.42.603.564.957.082.2.16.389.236.581.076.19.15.38.215.572.065.19.13.4.19.615.06.215.116.43.17.645.054.215.104.43.15.645.046.215.088.43.126.645.038.215.072.43.102.645.03.215.056.43.078.645.022.215.04.43.054.645.014.215.024.43.03.645 0 .317-.253.573-.57.573s-.57-.256-.57-.573c0-.215-.01-.43-.024-.645-.014-.215-.032-.43-.054-.645-.022-.215-.04-.43-.062-.645-.022-.215-.048-.43-.078-.645-.03-.215-.064-.43-.102-.645-.038-.215-.08-.43-.126-.645-.046-.215-.096-.43-.15-.645-.054-.215-.11-.43-.17-.645-.06-.215-.124-.43-.19-.615-.066-.185-.14-.375-.215-.572-.075-.197-.154-.386-.236-.581-.082-.195-.174-.38-.268-.564-.094-.184-.188-.368-.286-.552-.098-.184-.2-.366-.304-.548-.104-.182-.212-.362-.322-.54-.11-.178-.223-.354-.338-.528-.115-.174-.232-.346-.352-.516-.12-.17-.242-.338-.367-.504-.125-.166-.252-.33-.38-.492-.128-.162-.257-.322-.388-.48-.131-.158-.262-.314-.396-.468-.134-.154-.268-.306-.404-.456-.136-.15-.272-.298-.41-.444-.138-.146-.276-.29-.416-.432-.14-.142-.28-.282-.422-.42-.142-.138-.284-.274-.428-.408-.144-.134-.288-.266-.434-.396-.146-.13-.292-.258-.44-.384-.148-.126-.296-.25-.446-.372-.15-.122-.3-.242-.452-.36-.152-.118-.304-.234-.458-.348-.154-.114-.308-.226-.464-.336-.156-.11-.312-.218-.47-.324-.158-.106-.316-.21-.476-.312-.16-.102-.32-.202-.482-.3-.162-.098-.324-.194-.488-.288-.164-.094-.328-.186-.494-.276-.166-.09-.332-.178-.5-.264-.168-.086-.336-.17-.506-.252-.17-.082-.34-.162-.512-.24-.172-.078-.344-.154-.518-.228-.174-.074-.348-.146-.524-.216-.176-.07-.352-.138-.53-.204-.178-.066-.356-.13-.536-.192-.18-.062-.36-.122-.542-.18-.182-.058-.364-.114-.548-.168-.184-.054-.368-.106-.554-.156-.186-.05-.372-.098-.56-.144-.188-.046-.376-.09-.566-.132-.19-.042-.38-.082-.572-.12-.192-.038-.384-.074-.578-.108-.194-.034-.388-.066-.584-.096-.196-.03-.392-.058-.59-.084-.198-.026-.396-.05-.596-.072-.2-.022-.4-.042-.602-.06-.202-.018-.404-.034-.608-.048-.204-.014-.408-.026-.614-.036-.206-.01-.412-.018-.62-.024-.208-.006-.416-.01-.626-.012-.21-.002-.42-.002-.632-.002h-.064c-.212 0-.422 0-.632.002-.21.002-.418.006-.626.012-.208.006-.414.014-.62.024-.206.01-.41.022-.614.036-.204.014-.406.03-.608.048-.202.018-.402.038-.602.06-.2.022-.398.046-.596.072-.198.026-.392.054-.59.084-.196.03-.388.062-.584.096-.194.034-.388.074-.578.108-.192.038-.384.082-.572.12-.19.038-.378.086-.566.132-.188.046-.372.098-.56.144-.186.05-.368.102-.554.156-.184.054-.368.106-.548.168-.18.062-.36.122-.542.18-.182.058-.364.114-.548.168-.184.054-.368.106-.554.156-.186.05-.372.098-.56.144-.188.046-.376.09-.566.132-.19.042-.38.082-.572.12-.192.038-.384.074-.578.108-.194.034-.388.066-.584.096-.196.03-.392.058-.59.084-.198.026-.396.05-.596.072-.2.022-.4.042-.602.06-.202.018-.404.034-.608.048-.204.014-.408.026-.614.036-.206.01-.412.018-.62.024-.208.006-.416.01-.626.012-.21.002-.42.002-.632.002h-.064c-.212 0-.422 0-.632-.002-.21-.002-.418-.006-.626-.012-.208-.006-.414-.014-.62-.024-.206-.01-.41-.022-.614-.036-.204-.014-.406-.03-.608-.048-.202-.018-.402-.038-.602-.06-.2-.022-.398-.046-.596-.072-.198-.026-.392-.054-.59-.084-.196-.03-.388-.062-.584-.096-.194-.034-.388-.074-.578-.108-.192-.038-.384-.082-.572-.12-.19-.038-.378-.086-.566-.132-.188-.046-.372-.098-.56-.144-.186-.05-.368-.102-.554-.156-.184-.054-.368-.106-.548-.168-.18-.062-.36-.122-.542-.18-.182-.058-.364-.114-.548-.168-.184-.054-.368-.106-.554-.156-.186-.05-.372-.098-.56-.144-.188-.046-.376-.09-.566-.132-.19-.042-.38-.082-.572-.12-.192-.038-.384-.074-.578-.108-.194-.034-.388-.066-.584-.096-.196-.03-.392-.058-.59-.084-.198-.026-.396-.05-.596-.072-.2-.022-.4-.042-.602-.06-.202-.018-.404-.034-.608-.048-.204-.014-.408-.026-.614-.036-.206-.01-.412-.018-.62-.024-.208-.006-.416-.01-.626-.012-.21-.002-.42-.002-.632-.002h-.064z"/>
                  </svg>
                )}
              </a>
            ))}
          </div>
        </div>

        <!-- Navigation Links -->
        {Object.entries(footerLinks).map(([category, links]) => (
          <div class="footer-column">
            <h4 class="footer-column-title">{category}</h4>
            <ul class="footer-links-list">
              {links.map((link) => (
                <li>
                  <a href={link.href} class="footer-link">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Footer Bottom -->
  <div class="footer-bottom">
    <div class="container">
      <div class="footer-bottom-content">
        <p class="footer-copyright">
          &copy; <span id="footer-year">{currentYear}</span> ZyrithTech. All rights reserved.
        </p>
        <div class="footer-bottom-links">
          <a href="/privacy-policy" class="footer-bottom-link">Privacy Policy</a>
          <span class="footer-bottom-sep">·</span>
          <a href="/accessibility" class="footer-bottom-link">Accessibility Statement</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* ===============================
     FOOTER MAIN
     =============================== */
  .footer {
    background-color: var(--navy-900);
    color: var(--navy-100);
    margin-top: auto;
  }

  .footer-main {
    padding-block: var(--space-24);
    border-bottom: 1px solid var(--navy-700);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-12);
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }

  /* ===============================
     BRAND SECTION
     =============================== */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .footer-logo-img {
    height: 38px;
    width: auto;
  }

  .footer-tagline {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--navy-200);
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-style: normal; /* reset <address> italic */
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--navy-200);
  }

  .footer-contact-name {
    font-weight: 600;
    color: var(--navy-100);
  }

  .footer-contact-link {
    color: var(--navy-200);
    text-decoration: none;
    width: fit-content;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-contact-link:hover {
    color: var(--sky-300);
  }

  .footer-socials {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .footer-social-link {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.05);
    color: var(--sky-300);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color var(--duration-base) var(--ease-out),
                color var(--duration-base) var(--ease-out);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-social-link:hover {
    background-color: var(--sky-300);
    color: var(--navy-900);
  }

  /* ===============================
     FOOTER COLUMNS
     =============================== */
  .footer-column {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer-column-title {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--white);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  .footer-links-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
  }

  .footer-link {
    font-size: var(--text-sm);
    color: var(--navy-200);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-link:hover {
    color: var(--sky-300);
  }

  /* ===============================
     FOOTER BOTTOM
     =============================== */
  .footer-bottom {
    background-color: var(--navy-900);
    padding-block: var(--space-6);
    border-top: 1px solid var(--navy-700);
  }

  .footer-bottom-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  @media (max-width: 640px) {
    .footer-bottom-content {
      flex-direction: column;
      text-align: center;
    }
  }

  .footer-copyright {
    font-size: var(--text-xs);
    color: var(--navy-300);
  }

  .footer-bottom-links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .footer-bottom-link {
    font-size: var(--text-xs);
    color: var(--navy-300);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-bottom-link:hover {
    color: var(--sky-300);
  }

  .footer-bottom-sep {
    color: var(--navy-700);
  }

  /* ===============================
     ACCESSIBILITY
     =============================== */
  @media (prefers-reduced-motion: reduce) {
    .footer-social-link,
    .footer-link,
    .footer-contact-link {
      transition: none;
    }
  }
</style>

<script>
  // Update copyright year dynamically
  const yearElement = document.getElementById('footer-year');
  if (yearElement) {
    yearElement.textContent = new Date().getFullYear().toString();
  }
</script>
