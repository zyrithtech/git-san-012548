---
// src/components/BlogPostCard.astro
// Blog post card — used on /blog listing and "related posts" sections
import { sanityImageUrl } from '../lib/sanity';

interface Props {
  post: {
    title: string;
    excerpt?: string;
    slug: { current: string };
    mainImage?: any;
    publishedAt?: string;
    categories?: { title: string; slug?: { current: string } }[];
  };
  /* The /blog listing renders these straight under its h1, so they must be h2
     there. Under the "related posts" h2 on /post/[slug], h3 is correct. */
  headingLevel?: 2 | 3;
}

const { post, headingLevel = 3 } = Astro.props;
const Heading = `h${headingLevel}` as 'h2' | 'h3';
const imageUrl = post.mainImage ? sanityImageUrl(post.mainImage, 600) : null;
const publishDate = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
  : '';
---

<a href={`/post/${post.slug.current}/`} class="post-card">
  <div class="post-card-image">
    {imageUrl ? (
      <img
        src={imageUrl}
        alt={post.mainImage?.alt || post.title}
        width="600"
        height="315"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="post-card-image-fallback">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1.5">
          <rect x="3" y="4" width="18" height="16" rx="2"/>
          <path d="M3 9h18M8 4v5" stroke-linecap="round"/>
        </svg>
      </div>
    )}
  </div>
  <div class="post-card-body">
    <div class="post-card-meta">
      {post.categories && post.categories[0] && (
        <span class="post-card-cat">{post.categories[0].title}</span>
      )}
      {publishDate && <span class="post-card-date">{publishDate}</span>}
    </div>
    <Heading class="card-h3 post-card-title">{post.title}</Heading>
    {post.excerpt && <p class="post-card-excerpt">{post.excerpt}</p>}
    <span class="post-card-readmore">Read Article</span>
  </div>
</a>

<style>
  .post-card {
    background-color: var(--white);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: box-shadow var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .post-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
  }

  .post-card-image {
    height: 200px;
    overflow: hidden;
    background-color: var(--navy-50);
  }

  .post-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .post-card:hover .post-card-image img {
    transform: scale(1.03);
  }

  .post-card-image-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--navy-700), var(--navy-500));
  }

  .post-card-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .post-card-cat {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--sky-500);
  }

  .post-card-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .post-card-title {
    margin-bottom: var(--space-3);
  }

  .post-card-excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
    flex: 1;
  }

  .post-card-readmore {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--sky-500);
  }

  .post-card-readmore::after {
    content: '→';
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .post-card:hover .post-card-readmore {
    color: var(--sky-700);
  }

  .post-card:hover .post-card-readmore::after {
    transform: translateX(3px);
  }
</style>
