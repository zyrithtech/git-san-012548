---
// src/components/AnswerBlock.astro
// Answer-first (AEO) block: a question-shaped H2 followed by a direct 40-60 word
// answer. Placed high on the page so answer engines (Google AI Overviews,
// ChatGPT, Perplexity) can extract a clean, quotable definition. Intentionally
// NOT animated/hidden so the text is always present for crawlers.
interface Props {
  question: string;
  answer: string;
  label?: string;
  // When true, the block is removed from the visible layout but kept in the DOM
  // and the accessibility tree (screen-reader-only technique — NOT display:none),
  // so search engines and AI answer engines still read the text.
  visuallyHidden?: boolean;
  // When true, render as a native <details> accordion — compact and collapsed by
  // default, but fully rendered (real visible content, indexed at full weight).
  collapsible?: boolean;
  // Whether the accordion starts open (only applies when collapsible).
  open?: boolean;
}
const {
  question,
  answer,
  label = 'In short',
  visuallyHidden = false,
  collapsible = false,
  open = false,
} = Astro.props;
---
<section class={`answer-block${visuallyHidden ? ' answer-block--visually-hidden' : ''}`}>
  <div class="container">
    {collapsible ? (
      <details class="answer-details" open={open}>
        <summary class="answer-summary">
          <span class="answer-summary-main">
            <span class="answer-eyebrow">{label}</span>
            <h2 class="answer-question answer-question--compact">{question}</h2>
          </span>
          <svg class="answer-chevron" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <p class="answer-text answer-text--compact">{answer}</p>
      </details>
    ) : (
      <div class="answer-card">
        <span class="answer-eyebrow">{label}</span>
        <h2 class="answer-question">{question}</h2>
        <p class="answer-text">{answer}</p>
      </div>
    )}
  </div>
</section>

<style>
  .answer-block {
    background-color: var(--white);
    padding-block: var(--space-10);
  }
  /* Screen-reader-only: off-screen but still in the DOM + accessibility tree,
     so it stays crawlable/extractable while invisible to sighted users. */
  .answer-block--visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }
  .answer-card {
    max-width: 840px;
    border: 1px solid var(--color-border-default);
    border-left: 4px solid var(--sky-500);
    background-color: var(--sky-50);
    border-radius: var(--radius-lg);
    padding: var(--space-6) var(--space-8);
  }
  .answer-eyebrow {
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--sky-700);
    margin-bottom: var(--space-2);
  }
  .answer-question {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--navy-900);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-3);
  }
  .answer-text {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-body);
    margin: 0;
  }

  /* Collapsible (native <details>) variant — compact but fully rendered */
  .answer-details {
    max-width: 840px;
    border: 1px solid var(--color-border-default);
    border-left: 4px solid var(--sky-500);
    background-color: var(--sky-50);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .answer-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .answer-summary::-webkit-details-marker {
    display: none;
  }
  .answer-summary-main {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .answer-question--compact {
    margin: 0;
    font-size: var(--text-lg);
  }
  .answer-text--compact {
    padding: 0 var(--space-6) var(--space-5);
  }
  .answer-chevron {
    flex-shrink: 0;
    color: var(--sky-700);
    transition: transform var(--duration-base) var(--ease-out);
  }
  .answer-details[open] .answer-chevron {
    transform: rotate(180deg);
  }
  .answer-summary:focus-visible {
    outline: 2px solid var(--color-border-focus);
    outline-offset: -2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .answer-chevron {
      transition: none;
    }
  }
</style>
